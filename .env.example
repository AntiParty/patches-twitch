# Runtime
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
# Serve the built React SPA (frontend-react/dist) instead of the legacy EJS
# pages. Run `npm run build:web` first. Leave false to use the legacy frontend.
SERVE_REACT=false
SESSION_NAME=fsr.sid
SESSION_SECRET=replace_with_64_plus_random_chars
OAUTH_STATE_SECRET=replace_with_64_plus_random_chars
TOKEN_ENCRYPTION_KEY=replace_with_64_plus_random_chars

# Twitch application
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/callback

# Default bot account
TWITCH_BOT_USERNAME=
TWITCH_BOT_USER_ID=
TWITCH_BOT_TOKEN=
TWITCH_BOT_REFRESH_TOKEN=
TWITCH_APP_ACCESS_TOKEN=

# Admin and internal tools
ADMIN_USERS=
ADMIN_PASSWORD_HASH=
METRICS_PASSWORD=
DEPLOY_SECRET=
BACKUP_SECRET=

# Optional integrations
DISCORD_WEBHOOK_URL=
DISCORD_CHANGELOG_WEBHOOK_URL=
ADMIN_LOG_WEBHOOK=
FEEDBACK_DISCORD_WEBHOOK_URL=
EVENTSUB_SECRET=

# Optional subscription/payment integrations
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
