<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>FinalsRR - The Ultimate THE FINALS Twitch Bot for Player Stats</title>
    <link rel="icon" href="./assets/logo.png">
    <meta name="description" content="FinalsRR is the premier Twitch bot for THE FINALS, giving you real-time stats, leaderboards, and rank tracking for your Twitch channel." />
    <meta name="keywords" content="THE FINALS, Twitch bot, Twitch stats bot, FinalsRR, game stats, Twitch commands, THE FINALS leaderboard, Twitch integration" />
    <meta name="author" content="Antiparty" />
    <!-- ...existing meta tags... -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <style>
      body {
        background: #18181b;
        color: #e5e5e5;
        font-family: 'Segoe UI', Arial, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
      }
      .container {
        background: #23232a;
        border-radius: 16px;
        box-shadow: 0 4px 24px #000a;
        padding: 2.5rem 2rem;
        text-align: center;
        max-width: 400px;
      }
      .logo {
        width: 96px;
        margin-bottom: 1.5rem;
      }
      h1 {
        font-size: 2rem;
        margin-bottom: 0.5rem;
        color: #a970ff;
        letter-spacing: 1px;
      }
      .desc {
        font-size: 1.1rem;
        margin-bottom: 2rem;
        color: #bdbdbd;
      }
      .main-btn {
        display: inline-block;
        background: #a970ff;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 0.85rem 2.2rem;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        box-shadow: 0 2px 8px #0005;
        margin-bottom: 0.5rem;
      }
      .main-btn:hover {
        background: #7c4dff;
      }
      .footer {
        margin-top: 2rem;
        font-size: 0.95rem;
        color: #888;
      }
    </style>
    <div class="container">
      <img src="/assets/logo.png" alt="FinalsRR Logo" class="logo">
      <h1>FinalsRR Twitch Bot</h1>
      <div class="desc">
        The ultimate Twitch bot for competitive stats, rankings, and more.<br>
        Connect your Twitch account to get started!
      </div>
      <% if (isAuthed) { %>
        <a href="/dashboard" class="main-btn">Go to Dashboard</a>
        <div class="footer">You are already connected.</div>
      <% } else { %>
        <a href="/login" class="main-btn">Connect Twitch</a>
        <div class="footer">Secure Twitch authentication required.</div>
      <% } %>
    </div>
  </body>
</html>
