                    </div>
                    <span class="gs-step-action-status" id="gs-status-1"
                      >Pending</span
                    >
                  </div>
                  <div class="gs-step-action-description">
                    Make sure the bot is active to start using commands in your
                    chat.
                  </div>
                  <button
                    class="btn btn-primary gs-step-action-button"
                    onclick="goToStepAction(1)"
                  >
                    <i class="fas fa-arrow-right"></i> Go to Overview
                  </button>
                </div>
              </div>

              <!-- Step 2: Link Account -->
              <div id="gs-step-2" class="gs-step-container">
                <div class="gs-step-icon" id="gs-icon-2">
                  <i class="fas fa-link"></i>
                </div>
                <h3 class="gs-step-title">Link Your Game Account</h3>
                <p class="gs-step-description">
                  Connect your Embark ID to enable automatic stat tracking and
                  personalized responses.
                </p>
                <div class="gs-step-action" id="gs-action-2">
                  <div class="gs-step-action-header">
                    <div class="gs-step-action-title">
                      <i class="fas fa-gamepad"></i> Game Account
                    </div>
                    <span class="gs-step-action-status" id="gs-status-2"
                      >Pending</span
                    >
                  </div>
                  <div class="gs-step-action-description">
                    Add your Embark ID (e.g., PlayerName#1234) to enable stat
                    tracking.
                  </div>
                  <button
                    class="btn btn-primary gs-step-action-button"
                    onclick="goToStepAction(2)"
                  >
                    <i class="fas fa-arrow-right"></i> Go to Settings
                  </button>
                </div>
              </div>

              <!-- Step 3: Customize Commands -->
              <div id="gs-step-3" class="gs-step-container">
                <div class="gs-step-icon" id="gs-icon-3">
                  <i class="fas fa-terminal"></i>
                </div>
                <h3 class="gs-step-title">Customize Commands (Optional)</h3>
                <p class="gs-step-description">
                  Personalize your bot's responses to match your style and
                  branding.
                </p>
                <div class="gs-step-action" id="gs-action-3">
                  <div class="gs-step-action-header">
                    <div class="gs-step-action-title">
                      <i class="fas fa-code"></i> Custom Commands
                    </div>
                    <span class="gs-step-action-status" id="gs-status-3"
                      >Optional</span
                    >
                  </div>
                  <div class="gs-step-action-description">
                    Edit !rank, !record, and !peak command responses with custom
                    messages and variables.
                  </div>
                  <button
                    class="btn btn-primary gs-step-action-button"
                    onclick="goToStepAction(3)"
                  >
                    <i class="fas fa-arrow-right"></i> Go to Commands
                  </button>
                </div>
              </div>

              <!-- Step 4: Add Overlay -->
              <div id="gs-step-4" class="gs-step-container">
                <div class="gs-step-icon" id="gs-icon-4">
                  <i class="fas fa-tv"></i>
                </div>
                <h3 class="gs-step-title">Add Stream Overlay (Optional)</h3>
                <p class="gs-step-description">
                  Display your stats on stream with a customizable overlay that
                  updates in real-time.
                </p>
                <div class="gs-step-action" id="gs-action-4">
                  <div class="gs-step-action-header">
                    <div class="gs-step-action-title">
                      <i class="fas fa-broadcast-tower"></i> Stream Overlay
                    </div>
                    <span class="gs-step-action-status" id="gs-status-4"
                      >Optional</span
                    >
                  </div>
                  <div class="gs-step-action-description">
                    Copy your overlay URL and add it as a Browser Source in OBS Studio.
                    <div style="margin-top: 10px; display: flex; gap: 8px;">
                        <input type="text" class="input" readonly value="<%= process.env.BASE_URL || '' %>/overlays/overlay.html?token=<%= userStats.user?.overlay_token || 'TOKEN_HERE' %>" id="gs-overlay-url-input" style="font-size: 12px; padding: 8px;">
                        <button class="btn btn-ghost" onclick="copyGsOverlayUrl()">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                  </div>
                  <button
                    class="btn btn-primary gs-step-action-button"
                    onclick="goToStepAction(4)"
                  >
                    <i class="fas fa-arrow-right"></i> Go to Overlays
                  </button>
                  <script>
                    function copyGsOverlayUrl() {
                        const input = document.getElementById('gs-overlay-url-input');
                        // Use the token if available globally, else try to use the placeholder
                        if (overlayToken) {
                            input.value = `${window.location.origin}/overlays/overlay.html?token=${overlayToken}`;
                        }
                        input.select();
                        document.execCommand('copy');
                        showToast('Overlay URL copied!', 'success');
                    }
                    // Try to populate on load if token available
                    document.addEventListener('DOMContentLoaded', () => {
                         setTimeout(() => {
                             if(overlayToken) {
                                  const input = document.getElementById('gs-overlay-url-input');
                                  if(input) input.value = `${window.location.origin}/overlays/overlay.html?token=${overlayToken}`;
                             }
                         }, 1000);
                    });
                  </script>
                </div>
              </div>
            </div>

            <div class="gs-footer">
              <button class="gs-skip" onclick="skipOnboarding()">
                Skip for now
              </button>
              <div class="gs-nav-buttons">
                <button
                  id="gs-prev-btn"
                  class="btn btn-ghost"
                  onclick="previousStep()"
                  style="display: none"
                >
                  <i class="fas fa-arrow-left"></i> Previous
                </button>
                <button
                  id="gs-next-btn"
                  class="btn btn-primary"
                  onclick="nextStep()"
                >
                  Next <i class="fas fa-arrow-right"></i>
                </button>
                <button
                  id="gs-finish-btn"
                  class="btn btn-success-solid"
                  onclick="finishGettingStarted()"
                  style="display: none"
                >
                  <i class="fas fa-check"></i> Get Started!
                </button>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <div id="toast-container" class="toast-container"></div>

    <div id="confirm-modal" class="confirm-overlay">
      <div class="confirm-modal">
        <div id="confirm-title" class="confirm-title">Confirm Action</div>
        <div id="confirm-body" class="confirm-body">
          Are you sure you want to proceed?
        </div>
        <div class="confirm-actions">
          <button id="confirm-cancel" class="btn btn-ghost">Cancel</button>
          <button id="confirm-ok" class="btn btn-primary">Confirm</button>
        </div>
      </div>
    </div>

    <script>
      // Define switchView first to ensure it's always available
      function switchView(viewId) {
        document
          .querySelectorAll(".nav-item")
          .forEach((el) => el.classList.remove("active"));

        const activeNavItem = document.querySelector(
          `.nav-item[data-view="${viewId}"]`
        );
        if (activeNavItem) activeNavItem.classList.add("active");

        document
          .querySelectorAll(".view-section")
          .forEach((el) => el.classList.remove("active"));

        const viewElement = document.getElementById(`view-${viewId}`);
        if (viewElement) viewElement.classList.add("active");

        if (viewId === "commands" && typeof fetchCommands === "function") fetchCommands();
        if (viewId === "predictions" && typeof loadPredictions === "function") loadPredictions();
        if (viewId === "rank-tracker" && typeof loadRankGoal === "function") loadRankGoal();
        if (viewId === "analytics" && typeof loadAnalytics === "function") loadAnalytics();

        if (typeof checkOnboardingProgress === "function") {
          setTimeout(checkOnboardingProgress, 500);
        }
      }

      function showToast(message, type = "info") {
        const container = document.getElementById("toast-container");
        const toast = document.createElement("div");
        toast.className = `toast toast-${type}`;

        const icons = {
          success: "fa-check-circle",
          danger: "fa-exclamation-circle",
          warning: "fa-exclamation-triangle",
          info: "fa-info-circle",
        };

        toast.innerHTML = `
          <i class="fas ${icons[type]}"></i>
          <span>${message}</span>
        `;

        container.appendChild(toast);

        setTimeout(() => {
          toast.classList.add("fade-out");
          setTimeout(() => toast.remove(), 300);
        }, 4000);
      }

      function showConfirm(title, body) {
        return new Promise((resolve) => {
          const modal = document.getElementById("confirm-modal");
          const titleEl = document.getElementById("confirm-title");
          const bodyEl = document.getElementById("confirm-body");
          const cancelBtn = document.getElementById("confirm-cancel");
          const okBtn = document.getElementById("confirm-ok");

          titleEl.innerText = title;
          bodyEl.innerText = body;
          modal.style.display = "flex";

          const cleanup = (result) => {
            modal.style.display = "none";
            cancelBtn.onclick = null;
            okBtn.onclick = null;
            resolve(result);
          };

          cancelBtn.onclick = () => cleanup(false);
          okBtn.onclick = () => cleanup(true);
        });
      }

      function getCsrfHeaders() {
        const token = document
          .querySelector('meta[name="csrf-token"]')
          .getAttribute("content");
        return {
          "Content-Type": "application/json",
          "X-CSRF-Token": token,
        };
      }

      /* --- CLIENT STATE --- */
      const GS_KEY = "finalsrs_getting_started_seen";
      const GS_CHECKLIST_KEY = "finalsrs_checklist_hidden";
      const GS_COMPLETED_KEY = "finalsrs_onboarding_completed";

      // --- State ---
      let overlayToken = null;
      let overlayLayoutObj = null;
      let currentOnboardingStep = 1;
      const totalSteps = 4;

      // --- Onboarding Functions ---
      function openGettingStarted() {
        document.getElementById("getting-started-modal").style.display = "flex";
        currentOnboardingStep = 1;
        updateOnboardingStep();
        checkOnboardingProgress();
      }

      function closeGettingStarted() {
        document.getElementById("getting-started-modal").style.display = "none";
      }

      function skipOnboarding() {
        localStorage.setItem(GS_KEY, "true");
        closeGettingStarted();
        showOnboardingChecklist();
      }

      function finishGettingStarted() {
        localStorage.setItem(GS_KEY, "true");
        localStorage.setItem(GS_COMPLETED_KEY, "true");
        closeGettingStarted();
        hideOnboardingChecklist();
        showToast("Welcome aboard! You're all set! 🎉", "success");
      }

      function nextStep() {
        if (currentOnboardingStep < totalSteps) {
          currentOnboardingStep++;
          updateOnboardingStep();
        }
      }

      function previousStep() {
        if (currentOnboardingStep > 1) {
          currentOnboardingStep--;
          updateOnboardingStep();
        }
      }

      function updateOnboardingStep() {
        // Hide all steps
        for (let i = 1; i <= totalSteps; i++) {
          document.getElementById(`gs-step-${i}`).classList.remove("active");
        }

        // Show current step
        document
          .getElementById(`gs-step-${currentOnboardingStep}`)
          .classList.add("active");

        // Update progress
        const progress = (currentOnboardingStep / totalSteps) * 100;
        document.getElementById("gs-progress-fill").style.width =
          progress + "%";
        document.getElementById(
          "gs-progress-text"
        ).innerText = `Step ${currentOnboardingStep} of ${totalSteps}`;

        // Update navigation buttons
        const prevBtn = document.getElementById("gs-prev-btn");
        const nextBtn = document.getElementById("gs-next-btn");
        const finishBtn = document.getElementById("gs-finish-btn");

        prevBtn.style.display =
          currentOnboardingStep > 1 ? "inline-flex" : "none";
        nextBtn.style.display =
          currentOnboardingStep < totalSteps ? "inline-flex" : "none";
        finishBtn.style.display =
          currentOnboardingStep === totalSteps ? "inline-flex" : "none";

        // Check progress for current step
        checkOnboardingProgress();
      }

      let predictionPresets = [];
      let selectedPredictionPresetAlias = null;
      let editingPredictionPresetAlias = null;
      let activePredictionId = null;
      let predictionLoadPromise = null;
      let predictionAutomationConfig = null;

      function predictionElement(tag, className, text) {
        const element = document.createElement(tag);
        if (className) element.className = className;
        if (text !== undefined) element.textContent = text;
        return element;
      }

      async function predictionRequest(url, options = {}) {
        const headers = { ...(options.headers || {}) };
        if (options.body !== undefined) {
          headers["Content-Type"] = "application/json";
        }
        if (options.method && options.method !== "GET") {
          headers["X-CSRF-Token"] = document
            .querySelector('meta[name="csrf-token"]')
            .getAttribute("content");
        }

        const response = await fetch(url, { ...options, headers });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          const error = new Error(data.error || "Prediction request failed.");
          error.status = response.status;
          error.data = data;
          throw error;
        }
        return data;
      }

      function setPredictionAuthStatus(status) {
        const container = document.getElementById("prediction-auth-status");
        if (!container) return;
        container.className = "prediction-status";
        container.replaceChildren();

        const copy = predictionElement("div", "prediction-status-copy");
        const icon = predictionElement("div", "prediction-status-icon");
        const iconNode = predictionElement("i");
        const text = predictionElement("div");
        const title = predictionElement("div", "prediction-status-title");
        const detail = predictionElement("div", "prediction-status-detail");

        let action = null;
        if (status?.state === "ready") {
          container.classList.add("is-ready");
          iconNode.className = "fas fa-check";
          title.textContent = "Twitch predictions are ready";
          detail.textContent = "FinalsRS can create and manage Channel Points predictions for your channel.";
        } else if (status?.state === "reauth_required") {
          container.classList.add("is-warning");
          iconNode.className = "fas fa-key";
          title.textContent = "Twitch reauthorization required";
          detail.textContent = "Approve prediction access before starting or managing Channel Points predictions.";
          action = predictionElement("a", "btn btn-primary", "Reauthorize with Twitch");
          action.href = status.reauthUrl || "/reauth";
        } else if (status?.state === "unavailable") {
          container.classList.add("is-warning");
          iconNode.className = "fas fa-circle-exclamation";
          title.textContent = "Predictions are unavailable";
          detail.textContent = status.message || "Channel Points Predictions require Twitch Affiliate or Partner status.";
        } else {
          container.classList.add("is-warning");
          iconNode.className = "fas fa-triangle-exclamation";
          title.textContent = "Twitch is temporarily unavailable";
          detail.textContent = "Your presets are safe. Refresh this page and try again shortly.";
        }

        icon.appendChild(iconNode);
        text.append(title, detail);
        copy.append(icon, text);
        container.appendChild(copy);
        if (action) container.appendChild(action);
      }

      async function loadPredictions() {
        if (predictionLoadPromise) return predictionLoadPromise;
        const refreshButton = document.getElementById("prediction-refresh-button");
        const list = document.getElementById("prediction-presets-list");
        if (refreshButton) refreshButton.disabled = true;
        if (list) {
          const loading = predictionElement("div", "prediction-empty", "Loading presets...");
          list.replaceChildren(loading);
        }

        predictionLoadPromise = Promise.allSettled([
          predictionRequest("/api/user/predictions/status"),
          predictionRequest("/api/user/prediction-presets"),
          predictionRequest("/api/user/predictions/current"),
          predictionRequest("/api/user/predictions/automation"),
        ])
          .then(([statusResult, presetResult, currentResult, automationResult]) => {
            const status = statusResult.status === "fulfilled"
              ? statusResult.value
              : statusResult.reason?.data?.state === "reauth_required"
                ? {
                    state: "reauth_required",
                    reauthUrl: statusResult.reason.data.reauthUrl,
                  }
                : { state: "temporarily_unavailable" };
            predictionPresets = presetResult.status === "fulfilled"
              && Array.isArray(presetResult.value.presets)
              ? presetResult.value.presets
              : [];
            setPredictionAuthStatus(status);
            renderPredictionPresets(predictionPresets);
            renderActivePrediction(
              currentResult.status === "fulfilled"
                ? currentResult.value.prediction || null
                : null
            );
            renderSelectedPredictionPreset();
            if (automationResult.status === "fulfilled") {
              renderPredictionAutomation(automationResult.value);
            } else if (automationResult.reason?.data?.state === "subscription_required") {
              renderPredictionAutomationAccessRequired(automationResult.reason.data);
            } else {
              renderPredictionAutomationStatus(null, "Automatic prediction status is temporarily unavailable.");
            }
            if (presetResult.status === "rejected") {
              throw presetResult.reason;
            }
          })
          .catch((error) => {
            console.error("Failed to load prediction dashboard:", error);
            const status = error.data?.state === "reauth_required"
              ? { state: "reauth_required", reauthUrl: error.data.reauthUrl }
              : { state: "temporarily_unavailable" };
            setPredictionAuthStatus(status);
            showToast(error.message || "Failed to load predictions.", "danger");
          })
          .finally(() => {
            predictionLoadPromise = null;
            if (refreshButton) refreshButton.disabled = false;
          });

        return predictionLoadPromise;
      }

      function renderPredictionPresets(presets) {
        const list = document.getElementById("prediction-presets-list");
        if (!list) return;
        list.replaceChildren();

        if (!presets.length) {
          list.appendChild(predictionElement(
            "div",
            "prediction-empty",
            "No presets yet. Create one below, then start it from this page whenever you go live."
          ));
          return;
        }

        presets.forEach((preset) => {
          const card = predictionElement("div", "prediction-preset");
          if (preset.alias === selectedPredictionPresetAlias) card.classList.add("is-selected");

          const top = predictionElement("div", "prediction-preset-top");
          const identity = predictionElement("div");
          const title = predictionElement("div", "prediction-preset-title");
          title.textContent = preset.title;
          const alias = predictionElement("span", "prediction-alias", `!p start ${preset.alias}`);
          identity.append(title, alias);

          const actions = predictionElement("div", "prediction-preset-actions");
          const editButton = predictionElement("button", "btn btn-ghost btn-sm", "Edit");
          editButton.type = "button";
          editButton.addEventListener("click", () => editPredictionPreset(preset.alias));
          const selectButton = predictionElement("button", "btn btn-primary btn-sm", "Select");
          selectButton.type = "button";
          selectButton.addEventListener("click", () => selectPredictionPreset(preset.alias));
          const deleteButton = predictionElement("button", "btn btn-danger btn-sm", "Delete");
          deleteButton.type = "button";
          deleteButton.addEventListener("click", () => deletePredictionPreset(preset.alias));
          actions.append(editButton, selectButton, deleteButton);
          top.append(identity, actions);

          const outcomes = predictionElement("div", "prediction-outcome-summary");
          (preset.outcomes || []).forEach((outcome, index) => {
            const outcomeChip = predictionElement(
              "span",
              "prediction-outcome-chip",
              `${index + 1}. `
            );
            const outcomeText = predictionElement("span");
            outcomeChip.textContent = `${index + 1}. `;
            outcomeText.textContent = outcome;
            outcomeChip.appendChild(outcomeText);
            outcomes.appendChild(outcomeChip);
          });

          const meta = predictionElement(
            "div",
            "prediction-preset-meta",
            `${preset.durationSeconds}s voting window`
          );
          card.append(top, outcomes, meta);
          list.appendChild(card);
        });
      }

      function renderSelectedPredictionPreset() {
        const panel = document.getElementById("prediction-selected-preset");
        const startButton = document.getElementById("prediction-start-button");
        if (!panel || !startButton) return;
        const preset = predictionPresets.find(
          (item) => item.alias === selectedPredictionPresetAlias
        );
        panel.replaceChildren();
        if (!preset) {
          panel.className = "prediction-empty";
          panel.textContent = "Select a preset from the list to start it.";
          startButton.disabled = true;
          return;
        }
        panel.className = "prediction-preset is-selected";
        const title = predictionElement("div", "prediction-preset-title");
        title.textContent = preset.title;
        const alias = predictionElement("span", "prediction-alias", preset.alias);
        panel.append(title, alias);
        startButton.disabled = Boolean(activePredictionId);
      }

      function renderActivePrediction(prediction) {
        const panel = document.getElementById("active-prediction-panel");
        const startPanel = document.getElementById("prediction-start-panel");
        if (!panel || !startPanel) return;
        panel.replaceChildren();

        if (!prediction) {
          activePredictionId = null;
          const empty = predictionElement("div", "prediction-live-empty");
          const content = predictionElement("div");
          const icon = predictionElement("i");
          icon.className = "fas fa-chart-simple";
          icon.style.marginBottom = "10px";
          const text = predictionElement("div", "", "No active prediction. Select a preset below and start it.");
          content.append(icon, text);
          empty.appendChild(content);
          panel.appendChild(empty);
          startPanel.style.display = "block";
          renderSelectedPredictionPreset();
          return;
        }

        activePredictionId = prediction.id;
        startPanel.style.display = "none";

        const title = predictionElement("div", "prediction-live-title");
        title.textContent = prediction.title;
        const status = predictionElement("span", "prediction-live-status", prediction.status || "ACTIVE");
        const outcomes = predictionElement("div", "prediction-live-outcomes");

        (prediction.outcomes || []).forEach((outcome, index) => {
          const button = predictionElement("button", "btn btn-ghost prediction-resolve-button");
          button.type = "button";
          const number = predictionElement("span", "prediction-outcome-number", String(index + 1));
          const outcomeTitle = predictionElement("span");
          outcomeTitle.textContent = outcome.title;
          button.append(number, outcomeTitle);
          button.addEventListener("click", () => resolvePrediction(index + 1, outcome.title));
          outcomes.appendChild(button);
        });

        const actions = predictionElement("div", "prediction-live-actions");
        const cancelButton = predictionElement("button", "btn btn-danger-solid", "Cancel and refund");
        cancelButton.type = "button";
        cancelButton.addEventListener("click", cancelPrediction);
        actions.appendChild(cancelButton);
        panel.append(title, status, outcomes, actions);
      }

      function addPredictionOutcome(value = "") {
        const list = document.getElementById("prediction-outcomes-list");
        if (!list || list.children.length >= 5) return;
        const row = predictionElement("div", "prediction-outcome-row");
        const number = predictionElement(
          "div",
          "prediction-outcome-number",
          String(list.children.length + 1)
        );
        const input = predictionElement("input", "input");
        input.type = "text";
        input.maxLength = 25;
        input.required = true;
        input.placeholder = `Outcome ${list.children.length + 1}`;
        input.value = value;
        input.setAttribute("data-prediction-outcome", "true");

        const removeButton = predictionElement(
          "button",
          "btn btn-ghost prediction-icon-button"
        );
        removeButton.type = "button";
        removeButton.setAttribute("aria-label", "Remove outcome");
        const removeIcon = predictionElement("i");
        removeIcon.className = "fas fa-xmark";
        removeButton.appendChild(removeIcon);
        removeButton.addEventListener("click", () => {
          if (list.children.length <= 2) {
            showToast("A prediction needs at least two outcomes.", "warning");
            return;
          }
          row.remove();
          refreshPredictionOutcomeRows();
        });

        row.append(number, input, removeButton);
        list.appendChild(row);
        refreshPredictionOutcomeRows();
      }

      function refreshPredictionOutcomeRows() {
        const list = document.getElementById("prediction-outcomes-list");
        const addButton = document.getElementById("prediction-add-outcome-button");
        if (!list) return;
        Array.from(list.children).forEach((row, index) => {
          row.querySelector(".prediction-outcome-number").textContent = String(index + 1);
          row.querySelector("input").placeholder = `Outcome ${index + 1}`;
        });
        if (addButton) addButton.disabled = list.children.length >= 5;
      }

      function resetPredictionPresetForm(focusAlias = false) {
        editingPredictionPresetAlias = null;
        document.getElementById("prediction-form-title").textContent = "Create Preset";
        document.getElementById("prediction-alias-input").value = "";
        document.getElementById("prediction-alias-input").disabled = false;
        document.getElementById("prediction-title-input").value = "";
        document.getElementById("prediction-duration-input").value = "120";
        const outcomes = document.getElementById("prediction-outcomes-list");
        outcomes.replaceChildren();
        addPredictionOutcome();
        addPredictionOutcome();
        if (focusAlias) document.getElementById("prediction-alias-input").focus();
      }

      function editPredictionPreset(alias) {
        const preset = predictionPresets.find((item) => item.alias === alias);
        if (!preset) return;
        editingPredictionPresetAlias = preset.alias;
        document.getElementById("prediction-form-title").textContent = `Edit ${preset.alias}`;
        document.getElementById("prediction-alias-input").value = preset.alias;
        document.getElementById("prediction-alias-input").disabled = true;
        document.getElementById("prediction-title-input").value = preset.title;
        document.getElementById("prediction-duration-input").value = String(preset.durationSeconds);
        const outcomes = document.getElementById("prediction-outcomes-list");
        outcomes.replaceChildren();
        (preset.outcomes || []).forEach((outcome) => addPredictionOutcome(outcome));
        document.getElementById("prediction-title-input").focus();
      }

      async function savePredictionPreset(event) {
        event.preventDefault();
        const saveButton = document.getElementById("prediction-save-button");
        const alias = document.getElementById("prediction-alias-input").value.trim();
        const payload = {
          alias,
          title: document.getElementById("prediction-title-input").value.trim(),
          outcomes: Array.from(
            document.querySelectorAll("[data-prediction-outcome]")
          ).map((input) => input.value.trim()),
          durationSeconds: Number(document.getElementById("prediction-duration-input").value),
        };

        if (payload.outcomes.length < 2 || payload.outcomes.length > 5) {
          showToast("Use between two and five outcomes.", "warning");
          return;
        }

        const existing = predictionPresets.find((item) => item.alias === alias);
        if (!editingPredictionPresetAlias && existing) {
          const confirmed = await showConfirm(
            "Overwrite preset",
            `A preset named "${alias}" already exists. Replace it?`
          );
          if (!confirmed) return;
        }

        const originalLabel = saveButton.innerHTML;
        saveButton.disabled = true;
        saveButton.textContent = "Saving...";
        try {
          const url = editingPredictionPresetAlias
            ? `/api/user/prediction-presets/${encodeURIComponent(editingPredictionPresetAlias)}`
            : "/api/user/prediction-presets";
          const method = editingPredictionPresetAlias ? "PUT" : "POST";
          await predictionRequest(url, {
            method,
            body: JSON.stringify(payload),
          });
          showToast(
            editingPredictionPresetAlias ? "Preset updated." : "Preset saved.",
            "success"
          );
          selectedPredictionPresetAlias = alias.toLowerCase();
          resetPredictionPresetForm();
          await loadPredictions();
        } catch (error) {
          showToast(error.message || "Failed to save preset.", "danger");
        } finally {
          saveButton.disabled = false;
          saveButton.innerHTML = originalLabel;
        }
      }

      function selectPredictionPreset(alias) {
        selectedPredictionPresetAlias = alias;
        renderPredictionPresets(predictionPresets);
        renderSelectedPredictionPreset();
      }

      async function deletePredictionPreset(alias) {
        const confirmed = await showConfirm(
          "Delete prediction preset",
          `Delete "${alias}"? This cannot be undone.`
        );
        if (!confirmed) return;
        try {
          await predictionRequest(
            `/api/user/prediction-presets/${encodeURIComponent(alias)}`,
            { method: "DELETE" }
          );
          if (selectedPredictionPresetAlias === alias) selectedPredictionPresetAlias = null;
          if (editingPredictionPresetAlias === alias) resetPredictionPresetForm();
          showToast("Preset deleted.", "success");
          await loadPredictions();
        } catch (error) {
          showToast(error.message || "Failed to delete preset.", "danger");
        }
      }

      async function startPredictionFromSelectedPreset() {
        if (!selectedPredictionPresetAlias) {
          showToast("Select a preset first.", "warning");
          return;
        }
        const button = document.getElementById("prediction-start-button");
        button.disabled = true;
        try {
          const data = await predictionRequest("/api/user/predictions/start", {
            method: "POST",
            body: JSON.stringify({ alias: selectedPredictionPresetAlias }),
