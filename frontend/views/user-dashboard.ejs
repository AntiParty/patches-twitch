        try {
          const response = await fetch(`/api/overlay/config/${overlayToken}`);
          const config = await response.json();

          if (config) {
            document.getElementById("overlay-theme").value = config.theme;
            document.getElementById("overlay-color").value =
              config.primaryColor;
