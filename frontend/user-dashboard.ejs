<!DOCTYPE html>
<html lang="en">

<head>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0e0e10;
      --panel: #18181b;
      --panel-light: #1f1f23;
      --accent: #9146ff;
      --accent-hover: #b884ff;
      --accent-light: rgba(145, 70, 255, 0.1);
      --text: #efeff1;
      --muted: #a0a0aa;
      --border: #2a2a2e;
      --error: #f44336;
      --success: #4caf50;
      --radius: 0.75rem;
      --shadow: 0 4px 12px rgba(0, 0, 0, 0.15);
    }

    * {
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      line-height: 1.5;
    }

    /* NAV */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--panel);
      padding: 0.8rem 1.5rem;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: var(--shadow);
    }

    .navbar strong {
      color: var(--accent);
      font-size: 1.2rem;
      font-weight: 700;
    }

    .nav-links {
      display: flex;
      gap: 1.5rem;
    }

    .nav-links a {
      color: var(--text);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      transition: color 0.2s ease;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .nav-links a:hover {
      color: var(--accent);
    }

    .nav-links a::after {
      content: "↗";
      font-size: 0.7rem;
      opacity: 0.7;
    }

    /* HEADER */
    .welcome-header {
      max-width: 900px;
      width: 100%;
      margin: 2rem auto 1.5rem;
      padding: 2rem;
      background: linear-gradient(135deg, var(--panel) 0%, var(--panel-light) 100%);
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      gap: 1.5rem;
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .welcome-header::before {
      content: "";
      position: absolute;
      top: 0;
      right: 0;
      width: 150px;
      height: 150px;
      background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
      opacity: 0.05;
    }

    .welcome-header img {
      height: 60px;
      width: 60px;
      border-radius: 50%;
      border: 2px solid var(--accent);
      box-shadow: 0 0 15px rgba(145, 70, 255, 0.3);
    }

    .welcome-text h1 {
      margin: 0 0 0.5rem;
      font-size: 1.5rem;
      font-weight: 700;
    }

    .welcome-text p {
      margin: 0;
      color: var(--muted);
      font-size: 0.95rem;
    }

    /* MAIN */
    main {
      flex: 1;
      width: 100%;
      max-width: 900px;
      margin: 0 auto 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    section {
      background: var(--panel);
      border-radius: var(--radius);
      padding: 1.8rem;
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    section:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.2);
    }

    section h2 {
      font-size: 1.2rem;
      font-weight: 600;
      margin: 0 0 1.2rem;
      color: var(--accent);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    section h2::before {
      content: "";
      display: block;
      width: 4px;
      height: 1.2rem;
      background: var(--accent);
      border-radius: 2px;
    }

    /* INFO CARDS */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
    }

    .info-card {
      background: var(--panel-light);
      padding: 1.2rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }

    .info-card h3 {
      margin: 0 0 0.5rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .info-card p {
      margin: 0;
      font-size: 1rem;
      font-weight: 500;
    }

    /* COMMANDS TABLE */
    .commands-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 0.5rem;
    }

    .commands-table th,
    .commands-table td {
      font-size: 0.9rem;
      padding: 0.8rem;
      border-bottom: 1px solid var(--border);
      text-align: left;
    }

    .commands-table th {
      color: var(--muted);
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.5px;
      background: var(--panel-light);
    }

    .commands-table tr:last-child td {
      border-bottom: none;
    }

    .commands-table input {
      width: 100%;
      padding: 0.6rem 0.8rem;
      border-radius: 0.4rem;
      border: 1px solid var(--border);
      background: var(--panel-light);
      color: var(--text);
      font-size: 0.9rem;
      transition: border-color 0.2s ease;
    }

    .commands-table input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(145, 70, 255, 0.2);
    }

    .commands-table button {
      background: var(--accent);
      color: white;
      border: none;
      border-radius: 0.4rem;
      font-size: 0.8rem;
      padding: 0.5rem 1rem;
      cursor: pointer;
      font-weight: 600;
      transition: background 0.2s ease, transform 0.1s ease;
    }

    .commands-table button:hover {
      background: var(--accent-hover);
      transform: translateY(-1px);
    }

    .commands-table button:active {
      transform: translateY(0);
    }

    #command-status {
      margin-top: 0.8rem;
      font-size: 0.9rem;
      font-weight: 600;
      padding: 0.6rem 0.8rem;
      border-radius: 0.4rem;
      display: none;
    }

    /* CTA BUTTONS */
    .cta-row {
      display: flex;
      gap: 1rem;
      margin-top: 1rem;
    }

    .cta-button {
      flex: none;
      background: var(--accent);
      color: #fff;
      padding: 0.8rem 1.5rem;
      border-radius: 0.5rem;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      text-align: center;
      border: none;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.1s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .cta-button:hover {
      background: var(--accent-hover);
      transform: translateY(-2px);
    }

    .cta-button:active {
      transform: translateY(0);
    }

    .cta-button.danger {
      background: var(--error);
    }

    .cta-button.danger:hover {
      background: #e64545;
    }

    .cta-button.secondary {
      background: var(--panel-light);
      color: var(--text);
      border: 1px solid var(--border);
    }

    .cta-button.secondary:hover {
      background: var(--border);
    }

    /* FEATURES LIST */
    .features-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1rem;
    }

    .feature-item {
      background: var(--panel-light);
      padding: 1.2rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      transition: transform 0.2s ease;
    }

    .feature-item:hover {
      transform: translateY(-3px);
    }

    .feature-item h3 {
      margin: 0 0 0.5rem;
      font-size: 1rem;
      font-weight: 600;
      color: var(--accent);
    }

    .feature-item p {
      margin: 0;
      font-size: 0.9rem;
      color: var(--muted);
    }

    /* FOOTER */
    .site-footer {
      padding: 1.5rem 1.5rem;
      background: var(--panel);
      border-top: 1px solid var(--border);
      font-size: 0.8rem;
      color: var(--muted);
      text-align: center;
    }

    .footer-nav {
      margin-top: 0.8rem;
      display: flex;
      justify-content: center;
      gap: 1.5rem;
    }

    .footer-nav a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.85rem;
      transition: color 0.2s ease;
    }

    .footer-nav a:hover {
      color: var(--accent-hover);
    }

    /* Modal Styles */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      justify-content: center;
      align-items: center;
      z-index: 1000;
      backdrop-filter: blur(4px);
    }

    .modal-content {
      background: var(--panel);
      padding: 2.5rem;
      border-radius: var(--radius);
      max-width: 550px;
      width: 90%;
      text-align: center;
      border: 1px solid var(--border);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      position: relative;
    }

    .modal-content h2 {
      margin-top: 0;
      color: var(--accent);
    }

    .modal-content ol {
      text-align: left;
      margin: 1.5rem 0;
    }

    .modal-content li {
      margin-bottom: 0.8rem;
      padding-left: 0.5rem;
    }

    .modal-content strong {
      color: var(--accent);
    }

    .modal button {
      background: var(--accent);
      color: white;
      padding: 0.7rem 1.5rem;
      border: none;
      cursor: pointer;
      border-radius: var(--radius);
      font-weight: 600;
      transition: background 0.2s ease;
    }

    .modal button:hover {
      background: var(--accent-hover);
    }

    /* Quick Actions */
    .quick-actions {
      display: flex;
      gap: 1rem;
      margin-top: 1rem;
    }

    .quick-action {
      flex: 1;
      background: var(--accent-light);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem;
      text-align: center;
      transition: background 0.2s ease, transform 0.1s ease;
      cursor: pointer;
    }

    .quick-action:hover {
      background: rgba(145, 70, 255, 0.15);
      transform: translateY(-2px);
    }

    .quick-action h3 {
      margin: 0 0 0.5rem;
      font-size: 1rem;
      color: var(--accent);
    }

    .quick-action p {
      margin: 0;
      font-size: 0.85rem;
      color: var(--muted);
    }

    /* Responsive */
    @media (max-width: 768px) {
      .navbar {
        padding: 0.8rem 1rem;
      }

      .nav-links {
        gap: 1rem;
      }

      .welcome-header {
        flex-direction: column;
        text-align: center;
        padding: 1.5rem;
        margin: 1.5rem 1rem 1rem;
      }

      .welcome-header img {
        height: 50px;
        width: 50px;
      }

      .info-grid {
        grid-template-columns: 1fr;
      }

      .features-list {
        grid-template-columns: 1fr;
      }

      .cta-row {
        flex-direction: column;
      }

      .quick-actions {
        flex-direction: column;
      }

      section {
        padding: 1.5rem;
        margin: 0 1rem;
      }

      main {
        gap: 1.2rem;
      }
    }

    @media (max-width: 480px) {
      .navbar {
        flex-direction: column;
        gap: 0.8rem;
      }

      .nav-links {
        gap: 0.8rem;
      }

      .commands-table {
        font-size: 0.8rem;
      }

      .commands-table th,
      .commands-table td {
        padding: 0.6rem 0.4rem;
      }
    }
  </style>
  <link rel="icon" href="./assets/logo.png">
</head>

<body>
  <!-- NAVBAR -->
  <div class="navbar">
    <strong>FinalsRS Bot</strong>
    <nav class="nav-links">
      <a href="/">Home</a>
      <a href="https://twitter.com/AntipartyVAL" target="_blank">Twitter</a>
      <a href="https://discord.gg/2UKzvzSEqA" target="_blank">Discord</a>
    </nav>
  </div>

  <!-- WELCOME HEADER -->
  <div class="welcome-header">
    <img src="<%= logoPath %>" alt="Logo">
    <div class="welcome-text">
      <h1>Welcome, <%= username %>!</h1>
      <p>Your FinalsRS bot is ready to use. Customize your commands and get started below.</p>
    </div>
  </div>

  <!-- MAIN -->
  <main>
    <!-- Quick Actions -->
    <section>
      <h2>Quick Actions</h2>
      <div class="quick-actions">
        <div class="quick-action" onclick="showGuideModal()">
          <h3>Setup Guide</h3>
          <p>Get started with the bot</p>
        </div>
        <div class="quick-action" onclick="document.getElementById('commands-section').scrollIntoView({behavior: 'smooth'})">
          <h3>Customize Commands</h3>
          <p>Edit your bot responses</p>
        </div>
        <div class="quick-action" onclick="window.open('https://app.antiparty.dev/docs', '_blank')">
          <h3>Documentation</h3>
          <p>Learn advanced features</p>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section>
      <h2>Your Account Info</h2>
      <div class="info-grid">
        <div class="info-card">
          <h3>Twitch Username</h3>
          <p><%= userStats.username %></p>
        </div>
        <div class="info-card">
          <h3>Twitch User ID</h3>
          <p><%= userStats.twitchUserId %></p>
        </div>
        <div class="info-card">
          <h3>Linked Account</h3>
          <p><%= userStats.playerId ? userStats.playerId : "Not linked" %></p>
        </div>
        <div class="info-card">
          <h3>Status</h3>
          <p style="color: var(--success)">Active</p>
        </div>
      </div>
    </section>

    <!-- Commands -->
    <section>
      <h2>Customize Commands</h2>
      <p style="margin-bottom: 1rem; color: var(--muted);">Edit the responses for your bot commands.</p>
      <div id="commands-section">Loading commands...</div>
      <div id="command-status"></div>
      <div style="margin-top: 1rem; padding: 1rem; background: var(--accent-light); border-radius: var(--radius);">
        <p style="margin: 0; font-size: 0.9rem;">
          <strong>Tip:</strong> To learn how to customize your commands, visit 
          <a href="https://app.antiparty.dev/docs" target="_blank" style="color: var(--accent);">the documentation</a>.
        </p>
      </div>
    </section>

    <!-- Features -->
    <section>
      <h2>Coming Soon</h2>
      <div class="features-list">
        <div class="feature-item">
          <h3>Target Rank Goal</h3>
          <p>Calculates how far away you are from your target rank, and shows the <strong>RS</strong> (Rank Score) needed to reach your goal</p>
        </div>
        <div class="feature-item">
          <h3>Discord bot</h3>
          <p>Possible Discord bot (Still TBD)</p>
        </div>
        <div class="feature-item">
          <h3>Improve Documentation</h3>
          <p>Enhance the docs page to make it cleaner and easier to understand.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-row">
      <a href="/" class="cta-button secondary">
        <span>←</span> Back to Home
      </a>
      <button class="cta-button danger" id="disconnect-btn">
        <span>⚠</span> Disconnect Bot
      </button>
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <p>© 2025 FinalsRS. Third-party project, not affiliated with Embark Studios.</p>
    <nav class="footer-nav">
      <a href="/">Home</a>
      <a href="https://twitter.com/AntipartyVAL">Twitter</a>
      <a href="https://discord.gg/2UKzvzSEqA">Discord</a>
    </nav>
  </footer>

  <!-- Guide Modal -->
  <div class="modal" id="guide-modal">
    <div class="modal-content">
      <h2>Welcome to FinalsRS Bot</h2>
      <p>To get started, please follow these steps in your chat:</p>
      <ol>
        <li><strong>/mod FinalsRS</strong> to give the bot permissions</li>
        <li><strong>!link &lt;your_player_id&gt;</strong> to link your account (find your player ID in-game settings)</li>
        <li>Use commands like <strong>!rank</strong>, <strong>!record</strong>, and <strong>!peak</strong> to interact with the bot!</li>
      </ol>
      <button id="close-guide">Got it!</button>
    </div>
  </div>

  <!-- JS -->
  <script>
    async function fetchCommands() {
      const section = document.getElementById('commands-section');
      section.innerHTML = '<p style="padding: 1rem; text-align: center;">Loading commands...</p>';
      try {
        const res = await fetch('/api/my-commands');
        const data = await res.json();
        if (!data.commands) {
          section.innerHTML = '<p style="padding: 1rem; text-align: center; color: var(--muted)">No custom commands found.</p>';
          return;
        }
        const allowed = ['rank', 'record', 'peak'];
        let html = '<table class="commands-table"><tr><th>Command</th><th>Response</th><th></th></tr>';
        for (const cmd of allowed) {
          const found = data.commands.find(c => c.name === cmd);
          html += `<tr>
            <td style="font-weight: 600; color: var(--accent)">!${cmd}</td>
            <td><input type="text" id="cmd-${cmd}" value="${found ? found.response : ''}" placeholder="Enter response for !${cmd}" /></td>
            <td><button onclick="saveCommand('${cmd}')">Save</button></td>
          </tr>`;
        }
        html += '</table>';
        section.innerHTML = html;
      } catch {
        section.innerHTML = '<p style="padding: 1rem; text-align: center; color: var(--error)">Error loading commands.</p>';
      }
    }

    async function saveCommand(cmd) {
      const input = document.getElementById('cmd-' + cmd);
      const status = document.getElementById('command-status');
      status.textContent = '';
      status.style.display = 'block';
      
      // Add loading state
      const button = input.parentElement.nextElementSibling.querySelector('button');
      const originalText = button.textContent;
      button.textContent = 'Saving...';
      button.disabled = true;
      
      try {
        const res = await fetch('/api/my-commands', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: cmd, response: input.value })
        });
        const data = await res.json();
        if (data.success) {
          status.style.color = 'var(--success)';
          status.style.background = 'rgba(76, 175, 80, 0.1)';
          status.style.border = '1px solid rgba(76, 175, 80, 0.3)';
          status.textContent = `✓ Successfully saved !${cmd}`;
        } else {
          status.style.color = 'var(--error)';
          status.style.background = 'rgba(244, 67, 54, 0.1)';
          status.style.border = '1px solid rgba(244, 67, 54, 0.3)';
          status.textContent = data.error || 'Failed to save command.';
        }
      } catch {
        status.style.color = 'var(--error)';
        status.style.background = 'rgba(244, 67, 54, 0.1)';
        status.style.border = '1px solid rgba(244, 67, 54, 0.3)';
        status.textContent = 'Error saving command. Please try again.';
      } finally {
        button.textContent = originalText;
        button.disabled = false;
        
        // Hide status after 3 seconds
        setTimeout(() => {
          status.style.display = 'none';
        }, 3000);
      }
    }

    function showGuideModal() {
      const modal = document.getElementById('guide-modal');
      const closeBtn = document.getElementById('close-guide');

      modal.style.display = 'flex';
      closeBtn.addEventListener('click', () => {
        modal.style.display = 'none';
        localStorage.setItem('hasSeenGuide', 'true');
      });
      
      // Also close modal when clicking outside
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.style.display = 'none';
          localStorage.setItem('hasSeenGuide', 'true');
        }
      });
    }

    // Disconnect Bot Logic
    document.getElementById('disconnect-btn').addEventListener('click', function () {
      if (window.confirm('Are you sure you want to disconnect and remove your bot/service? This action cannot be undone.')) {
        disconnectBot();
      }
    });

    async function disconnectBot() {
      const status = document.getElementById('command-status');
      status.textContent = '';
      status.style.display = 'block';
      
      const button = document.getElementById('disconnect-btn');
      const originalText = button.textContent;
      button.textContent = 'Disconnecting...';
      button.disabled = true;
      
      try {
        const res = await fetch('/api/disconnect-bot', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        if (data.success) {
          status.style.color = 'var(--success)';
          status.style.background = 'rgba(76, 175, 80, 0.1)';
          status.style.border = '1px solid rgba(76, 175, 80, 0.3)';
          status.textContent = 'Bot/service successfully disconnected and removed.';
          setTimeout(() => { window.location.href = '/'; }, 1500);
        } else {
          status.style.color = 'var(--error)';
          status.style.background = 'rgba(244, 67, 54, 0.1)';
          status.style.border = '1px solid rgba(244, 67, 54, 0.3)';
          status.textContent = data.error || 'Failed to disconnect. Please try again.';
          button.textContent = originalText;
          button.disabled = false;
        }
      } catch {
        status.style.color = 'var(--error)';
        status.style.background = 'rgba(244, 67, 54, 0.1)';
        status.style.border = '1px solid rgba(244, 67, 54, 0.3)';
        status.textContent = 'Error disconnecting. Please try again.';
        button.textContent = originalText;
        button.disabled = false;
      }
    }

    window.addEventListener('DOMContentLoaded', () => {
      fetchCommands();
      
      // Show guide modal only if user hasn't seen it before
      if (!localStorage.getItem('hasSeenGuide')) {
        setTimeout(showGuideModal, 1000);
      }
    });
  </script>
</body>
</html>