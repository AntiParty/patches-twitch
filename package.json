{
  "name": "patches-twitch",
  "version": "1.0.0",
  "description": "Twitch bot and web dashboard for THE FINALS ranked stats, stream overlays, and chat commands.",
  "main": "dist/index.js",
  "scripts": {
    "dev:server": "NODE_ENV=development bun run --watch src/index.ts",
    "dev:bot": "NODE_ENV=development bun run --watch src/botService.ts",
    "dev:all": "concurrently -n server,bot -c green,blue \"bun run dev:server\" \"bun run dev:bot\"",
    "start:server": "NODE_ENV=production bun run dist/index.js",
    "start:bot": "NODE_ENV=production bun run dist/bot.js",
    "start:all": "concurrently -n server,bot -c green,blue \"bun run start:server\" \"bun run start:bot\"",
    "build": "tsc",
    "test": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register \"src/tests/**/*.test.ts\" --timeout 10000",
    "test:unit": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register \"src/tests/unit/**/*.test.ts\" --timeout 5000",
    "test:integration": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register \"src/tests/integration/**/*.test.ts\" --timeout 15000",
    "test:watch": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register \"src/tests/**/*.test.ts\" --watch --watch-extensions ts"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/csurf": "^1.11.5",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/sequelize": "^4.28.20",
    "axios": "^1.12.0",
    "bcrypt": "^6.0.0",
    "connect-session-sequelize": "^8.0.3",
    "csurf": "^1.11.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "eventsource": "^4.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "multer": "^2.0.2",
    "mysql2": "^3.11.5",
    "open": "^10.2.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.3",
    "sqlite3": "^5.1.7",
    "tar": "^7.4.3",
    "tsconfig-paths": "^4.2.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node-fetch": "^2.6.13",
    "concurrently": "^9.2.1",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  },
  "keywords": [
    "twitch",
    "bot",
    "the-finals",
    "leaderboard",
    "streaming"
  ],
  "author": "antiparty",
  "license": "MIT"
}
