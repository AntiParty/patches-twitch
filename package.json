{
  "name": "patches-twitch",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev:server": "NODE_ENV=development bun run src/index.ts",
    "dev:bot": "NODE_ENV=development bun run src/botService.ts",
    "dev:all": "concurrently -n server,bot -c green,blue \"bun run dev:server\" \"bun run dev:bot\"",
    "start:server": "NODE_ENV=production bun run dist/index.js",
    "start:bot": "NODE_ENV=production bun run dist/bot.js",
    "start:all": "concurrently -n server,bot -c green,blue \"bun run start:server\" \"bun run start:bot\"",
    "build": "tsc"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/csurf": "^1.11.5",
    "@types/express-session": "^1.18.2",
    "@types/sequelize": "^4.28.20",
    "axios": "^1.7.9",
    "bcrypt": "^6.0.0",
    "csurf": "^1.11.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "mysql2": "^3.11.5",
    "open": "^10.2.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "sequelize": "^6.37.5",
    "sqlite3": "^5.1.7",
    "tmi.js": "^1.8.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node-fetch": "^2.6.13",
    "concurrently": "^9.2.1",
    "typescript": "^5.1.3"
  },
