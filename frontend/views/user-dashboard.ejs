      function renderPredictionAutomationStatus(run, fallback, live = null) {
        const panel = document.getElementById("prediction-automation-status");
        if (!panel) return;
        panel.replaceChildren();
        const title = predictionElement(
          "div",
          "prediction-live-title",
          run ? String(run.status || "unknown").replaceAll("_", " ") : (fallback || "Waiting for a stream")
        );
        const detail = predictionElement(
          "div",
          "prediction-card-copy",
          run?.failureReason
            ? `Reason: ${String(run.failureReason).replaceAll("_", " ")}`
            : "FinalsRS will use the existing session starting RS and settle only its stored Twitch prediction."
        );
        panel.append(title, detail);
        if (live) {
          const metrics = predictionElement("div", "prediction-outcome-summary");
          const values = [
            ["Stream", live.isLive ? (live.category || "Live") : "Offline"],
            ["Starting RS", live.startingRs === null ? "Waiting" : Number(live.startingRs).toLocaleString()],
            ["Latest RS", live.latestRs === null ? "Unavailable" : Number(live.latestRs).toLocaleString()],
            ["Delta", live.delta === null ? "Unavailable" : `${live.delta >= 0 ? "+" : ""}${Number(live.delta).toLocaleString()}`],
          ];
          if (live.secondsUntilStart !== null && live.secondsUntilStart > 0) {
            values.push(["Auto-start", `${Math.ceil(live.secondsUntilStart / 60)}m`]);
          }
          values.forEach(([label, value]) => {
            metrics.appendChild(predictionElement(
              "span",
              "prediction-outcome-chip",
              `${label}: ${value}`
            ));
          });
          panel.appendChild(metrics);
        }
      }

      function readPredictionAutomationOutcomes() {
        return Array.from(document.getElementById("prediction-automation-outcomes").children).map((row) => {
          const label = row.querySelector("[data-auto-outcome-label]").value.trim();
          const minimum = row.querySelector("[data-auto-outcome-min]").value;
          const maximum = row.querySelector("[data-auto-outcome-max]").value;
          return {
            label,
            minDelta: minimum === "" ? null : Number(minimum),
            maxDelta: maximum === "" ? null : Number(maximum),
          };
        });
      }

