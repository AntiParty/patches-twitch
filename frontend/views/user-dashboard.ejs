                  <span class="value" style="color: var(--warning);">Role Access (<%= role %>)</span>
                </div>
                <% } %>
              </div>
              <button class="btn btn-ghost" style="margin-top: 16px;" onclick="refreshPremiumStatus()">
                <i class="fas fa-sync"></i> Refresh Status
              </button>
              <% } else { %>
              <p style="color: var(--text-muted);">No active premium access.</p>
              <p style="font-size: 13px; color: var(--text-muted); margin-top: 8px;">Subscribe to antiparty on Twitch to unlock premium features!</p>
              <button class="btn btn-primary" style="margin-top: 16px;" onclick="window.location.href='/subscribe'">
                Get Premium
              </button>
              <% } %>
            </div>

            <!-- Custom Bot Status -->
            <div class="status-card">
              <div class="card-title">Custom Bot Account</div>
              <% if (customBot) { %>
              <div class="bot-info">
                <div class="bot-avatar">
                  <div class="bot-icon">🤖</div>
                </div>
                <div class="bot-details">
                  <h3><%= customBot.bot_username %></h3>
                  <p class="bot-status">
                    <span
                      class="status-dot <%= customBot.is_active ? 'active' : 'inactive' %>"
                    ></span>
                    <%= customBot.is_active ? 'Active' : 'Inactive' %>
                  </p>
                </div>
              </div>
              <div class="bot-actions">
                <button class="btn btn-danger" id="unlinkBotBtn">
                  Unlink Bot
                </button>
                <a href="/link-custom-bot" class="btn btn-primary"
                  >Link Different Bot</a
                >
              </div>
              <% } else { %>
              <p style="color: var(--text-muted);">No custom bot linked yet.</p>
              <% if (hasSubscription) { %>
              <div style="display: flex; gap: 10px; align-items: center; margin-top: 1rem;">
                <a href="/link-custom-bot" class="btn btn-primary" style="margin: 0;">Link Custom Bot</a>
                <button class="btn btn-ghost" onclick="copyCustomBotAuthLink()" title="Copy Link to authorize in another browser">
                    <i class="fas fa-copy"></i>
                </button>
              </div>
              <% } else { %>
                <p style="font-size: 13px; color: var(--text-muted); margin-top: 8px;">Subscribe to antiparty on Twitch to link a custom bot.</p>
                <a href="/subscribe" class="btn btn-primary" style="margin-top: 8px;">Get Premium</a>
              <% } %>
              <% } %>
            </div>
          </div>

          <!-- Setup Guide -->
          <div class="guide-card">
            <div class="card-title">How to Set Up Your Custom Bot</div>
            <ol class="setup-steps">
              <li>
                <strong>Create a Twitch Account</strong>
                <p>
                  Create a new Twitch account with your desired bot name (e.g.,
                  "YourNameBot").
                </p>
              </li>
              <li>
                <strong>Link Your Bot</strong>
                <p>
                  Click "Link Custom Bot" above.
                  <br><span style="font-size: 13px; color: var(--text-muted);">Tip: Use the copy button <i class="fas fa-copy" style="font-size: 11px;"></i> if you need to open the link in an Incognito window or another browser where your bot account is logged in.</span>
                </p>
              </li>
              <li>
                <strong>You're Done!</strong>
                <p>
                  Your bot will now respond in your chat using your custom account.
                </p>
              </li>
              <script>
                async function copyCustomBotAuthLink() {
                    try {
                        const res = await fetch('/api/subscription/custom-bot-auth-url');
                        const data = await res.json();
                        if (data.url) {
                            await navigator.clipboard.writeText(data.url);
                            showToast('Link copied! Open it in the browser where your bot is logged in.', 'success');
                        } else {
                            showToast('Failed to get link', 'danger');
                        }
                    } catch (e) {
                         console.error(e);
                         showToast('Error getting link', 'danger');
                    }
                }

                async function refreshPremiumStatus() {
                    try {
                        const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute("content");
                        const res = await fetch('/api/subscription/refresh', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-CSRF-Token': csrfToken
                            }
                        });
                        const data = await res.json();

                        if (data.needsReauth) {
                            // User needs to re-authorize for subscription scope
                            showToast('Re-authorizing with Twitch...', 'info');
                            window.location.href = data.reauthUrl || '/reauth';
                        } else if (data.success) {
                            showToast(data.message, data.hasSubscription ? 'success' : 'info');
                            // Reload page to reflect updated status
                            setTimeout(() => window.location.reload(), 1500);
                        } else {
                            showToast('Failed to refresh status', 'danger');
                        }
                    } catch (e) {
                        console.error(e);
                        showToast('Error refreshing status', 'danger');
                    }
                }
              </script>
            </ol>
          </div>

          <script>
            // Unlink bot handler
            document.addEventListener("DOMContentLoaded", () => {
                const unlinkBtn = document.getElementById("unlinkBotBtn");
                if (unlinkBtn) {
                  unlinkBtn.addEventListener("click", async () => {
                    if (
                      !confirm(
                        "Are you sure you want to unlink your custom bot? The bot will revert to using the default account.",
                      )
                    ) {
                      return;
                    }
          
                    unlinkBtn.disabled = true;
                    unlinkBtn.innerText = "Unlinking...";
          
                    try {
                      const response = await fetch("/api/subscription/unlink-bot", {
                        method: "POST",
                        headers: { 
                            "Content-Type": "application/json",
                            "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').getAttribute("content")
                        },
                      });
          
                      if (response.ok) {
                        window.location.reload();
                      } else {
                        alert("Failed to unlink bot. Please try again.");
                      }
                    } catch (error) {
                      console.error("Unlink error:", error);
                      alert("Failed to unlink bot. Please try again.");
                    } finally {
                      unlinkBtn.disabled = false;
                      unlinkBtn.innerText = "Unlink Bot";
                    }
                  });
                }
            });
          </script>
