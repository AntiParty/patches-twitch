<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    <link rel="canonical" href="https://finalsrs.com/blog/<%= post.slug %>">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="FinalsRS" />
    <meta property="og:title" content="<%= title %>" />
    <meta property="og:description" content="<%= description %>" />
    <meta property="og:image" content="https://finalsrs.com<%= post.image %>" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="https://finalsrs.com/blog/<%= post.slug %>" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= title %>" />
    <meta name="twitter:description" content="<%= description %>" />
    <meta name="twitter:image" content="https://finalsrs.com<%= post.image %>" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": "<%= post.title %>",
        "image": "https://finalsrs.com<%= post.image %>",
        "author": {
          "@type": "Person",
          "name": "<%= post.author %>"
        },
        "publisher": {
          "@type": "Organization",
          "name": "FinalsRS",
          "logo": {
            "@type": "ImageObject",
            "url": "https://finalsrs.com/assets/logo.png"
          }
        },
        "datePublished": "<%= post.date %>",
        "dateModified": "<%= post.date %>",
        "description": "<%= description %>",
        "mainEntityOfPage": "https://finalsrs.com/blog/<%= post.slug %>"
      }
    </script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    
    <link rel="icon" href="/assets/logo.png">
    <link rel="stylesheet" href="/styles.css">
    
    <style>
        .post-hero {
            padding: 10rem 0 4rem;
            position: relative;
            background: radial-gradient(circle at 50% 0%, rgba(217, 0, 47, 0.05) 0%, transparent 50%);
        }

        .post-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        .post-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .post-category {
            color: var(--brand-primary);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            display: block;
        }

        .post-header h1 {
            font-size: 3.5rem;
            font-weight: 800;
            letter-spacing: -1.5px;
            line-height: 1.1;
            margin-bottom: 2rem;
        }

        .post-meta {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 2rem;
            color: var(--text-tertiary);
            font-size: 0.95rem;
        }

        .author-box {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .author-avatar {
            width: 32px;
            height: 32px;
            background: var(--brand-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 0.8rem;
        }

        .post-featured-image {
            width: 100%;
            border-radius: var(--radius-lg);
            margin-bottom: 4rem;
            border: 1px solid var(--border-color);
        }

        /* Typography Focus */
        .post-body {
            font-size: 1.15rem;
            line-height: 1.8;
            color: var(--text-secondary);
        }

        .post-body h2 {
            font-size: 2rem;
            color: var(--text-primary);
            margin: 3rem 0 1.5rem;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .post-body h3 {
            font-size: 1.5rem;
            color: var(--text-primary);
            margin: 2rem 0 1rem;
            font-weight: 700;
        }

        .post-body p {
            margin-bottom: 1.5rem;
        }

        .post-body ul {
            margin-bottom: 1.5rem;
            padding-left: 1.5rem;
        }

        .post-body li {
            margin-bottom: 0.5rem;
        }

        .post-body strong {
            color: var(--text-primary);
        }

        .post-body code {
            background: rgba(255,255,255,0.05);
            padding: 0.2rem 0.4rem;
            border-radius: 4px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9em;
            color: var(--brand-primary);
        }

        .post-footer {
            margin-top: 6rem;
            padding-top: 4rem;
            border-top: 1px solid var(--border-color);
            text-align: center;
        }

        .share-box {
            margin-bottom: 4rem;
        }

        .share-box h4 {
            margin-bottom: 1.5rem;
            color: var(--text-primary);
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">
                <span class="logo-icon"><img src="/assets/logo.png" alt="FinalsRS Logo"></span>
                FinalsRS
            </a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/twitch-drops">Drops</a>
                <a href="/docs">Docs</a>
                <a href="/blog">Blog</a>
                <a href="/login" class="btn-login">Log in</a>
            </div>
        </div>
    </nav>

    <article class="post-hero">
        <div class="post-container">
            <header class="post-header">
                <span class="post-category"><%= post.category %></span>
                <h1><%= post.title %></h1>
                <div class="post-meta">
                    <div class="author-box">
                        <div class="author-avatar"><%= post.author.charAt(0) %></div>
                        <span><%= post.author %></span>
                    </div>
                    <span><%= post.date %></span>
                    <span><%= post.readingTime %></span>
                </div>
            </header>

            <img src="<%= post.image %>" alt="<%= post.title %>" class="post-featured-image">

            <div class="post-body">
                <%- post.content %>
            </div>

            <footer class="post-footer">
                <div class="share-box">
                    <h4>Share this article</h4>
                    <!-- Social share links would go here -->
                </div>
                
                <div class="cta-box">
                    <h3>Want to see these stats live?</h3>
                    <p>Add FinalsRS to your Twitch channel in seconds.</p>
                    <a href="/login" class="btn-primary large">Add to Twitch</a>
                </div>
            </footer>
        </div>
    </article>

    <footer>
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h3>FinalsRS</h3>
                    <p>The unofficial companion bot for THE FINALS. Master the arena with real-time stats.</p>
                </div>
                <div class="footer-col">
                    <h4>Product</h4>
                    <a href="/#features">Features</a>
                    <a href="/twitch-drops">Drops</a>
                </div>
                <div class="footer-col">
                    <h4>Resources</h4>
                    <a href="/docs">Documentation</a>
                    <a href="/blog">Blog</a>
                    <a href="https://discord.com/invite/2UKzvzSEqA">Support</a>
                </div>
                <div class="footer-col">
                    <h4>Legal</h4>
                    <a href="/legal">Privacy</a>
                    <a href="/legal#">Terms</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 FinalsRS. Not affiliated with Embark Studios.</p>
            </div>
        </div>
    </footer>
</body>
</html>
