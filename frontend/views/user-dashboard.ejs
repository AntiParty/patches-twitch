      // Render the variable chips for a given command
      function updateVariables(cmd) {
        const panel = document.getElementById("cmd-variables");
        const label = document.getElementById("cmd-variables-label");
        const vars = cmdVars[cmd];
        if (!panel || !vars) return;

        if (label) label.textContent = `for !${cmd}`;

        panel.innerHTML = vars.map(({ v, desc }) => `
          <div
            onclick="insertVariable('${cmd}', '{${v}}')"
            title="Click to insert"
            style="
              font-size: 12px;
              background: var(--bg-app);
              padding: 8px 10px;
              border-radius: 4px;
              cursor: pointer;
              border: 1px solid transparent;
              transition: border-color 0.15s;
            "
            onmouseenter="this.style.borderColor='var(--primary)'"
            onmouseleave="this.style.borderColor='transparent'"
          >
            <code style="color: var(--primary); font-weight: 700">{${v}}</code>
            <div style="color: var(--text-muted); margin-top: 2px">${desc}</div>
          </div>
        `).join("");
      }

      // Insert a variable at the cursor position in the active input
      function insertVariable(cmd, variable) {
        const input = document.getElementById(`input-${cmd}`);
        if (!input) return;
        const start = input.selectionStart ?? input.value.length;
        const end = input.selectionEnd ?? input.value.length;
        input.value = input.value.slice(0, start) + variable + input.value.slice(end);
        input.focus();
        input.selectionStart = input.selectionEnd = start + variable.length;
        updatePreview(cmd, input.value);
      }

      // --- Commands & Preview ---
      async function fetchCommands() {
        const list = document.getElementById("commands-list");
        list.innerHTML =
          '<div style="text-align: center; padding: 20px; color: var(--text-muted);">Loading...</div>';

        try {
          const res = await fetch("/api/my-commands");
          const data = await res.json();

          if (!data.commands) {
            list.innerHTML =
              '<div style="text-align: center;">No commands found</div>';
            return;
          }

          const allowed = ["rank", "record", "peak"];
          let html = "";

          for (const cmd of allowed) {
            const found = data.commands.find((c) => c.name === cmd);
            const val = found ? found.response : "";
            const isCustom = val.trim().length > 0;
            html += `
              <div style="background: var(--bg-hover); padding: 16px; border-radius: var(--radius); border: 1px solid var(--border);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                  <span style="font-weight: 600; color: var(--primary);">!${cmd}</span>
                  <div style="display: flex; align-items: center; gap: 8px;">
                    ${isCustom ? `<span style="font-size: 11px; color: var(--success); background: rgba(0,179,95,0.12); padding: 2px 7px; border-radius: 10px;">Custom</span>` : `<span style="font-size: 11px; color: var(--text-muted);">Default</span>`}
                    <button
                      class="btn btn-ghost btn-sm"
                      style="font-size: 11px; padding: 2px 8px; color: var(--text-muted);"
                      onclick="resetCommand('${cmd}')"
                      title="Reset to default bot response"
                    >Reset</button>
                  </div>
                </div>
                <div style="display: flex; gap: 10px;">
                  <input
                    id="input-${cmd}"
                    class="input"
                    value="${val.replace(/"/g, '&quot;')}"
                    placeholder="Leave blank to use the default response…"
                    oninput="updatePreview('${cmd}', this.value)"
                    onfocus="updateVariables('${cmd}'); updatePreview('${cmd}', this.value);"
                  >
                  <button class="btn btn-success btn-sm" onclick="saveCommand('${cmd}')">Save</button>
                </div>
              </div>
            `;
          }
          list.innerHTML = html;
        } catch (e) {
          list.innerHTML =
            '<div style="color: var(--danger); text-align: center;">Failed to load commands</div>';
        }
      }

      /* --- helpers --- */
      function parseNumber(value) {
        if (value == null) return NaN;
        if (typeof value === "number") return value;
        const n = Number(String(value).replace(/[^0-9.-]+/g, ""));
        return isNaN(n) ? NaN : n;
      }

      function formatNumber(n) {
        return Number(n).toLocaleString();
      }

      let latestCurrentRank = null;

      function getSelectedTargetRank() {
        const targetRankSelect = document.getElementById("target-rank-select");
        return Number(targetRankSelect?.value);
      }

      function hasRubyAchievement(rankData) {
        if (!rankData) return false;
        const leaderboardRank = parseNumber(rankData.rank);
        return String(rankData.league || "").toLowerCase() === "ruby" ||
          (!isNaN(leaderboardRank) && leaderboardRank > 0 && leaderboardRank <= 500);
      }

      function getNextRankMilestone(currentRSRaw) {
        const currentRS = parseNumber(currentRSRaw);
        if (isNaN(currentRS)) return null;
        return rankMilestones.find((milestone) => currentRS < milestone.threshold) || {
          rank: 6,
          label: "Ruby",
          threshold: null,
        };
      }

      async function fetchCurrentRank() {
        const status = document.getElementById("current-rank-status");
        try {
          if (status) status.innerText = "Checking latest leaderboard cache...";
          const res = await fetch("/api/my-current-rank", { cache: "no-store" });
          const data = await res.json();

          if (!res.ok) {
            if (status) {
              status.innerText = data.error || "Current RS is unavailable.";
            }
            return null;
          }

          if (status) {
            const bits = [
              `${formatNumber(data.rankScore)} RS`,
              data.league,
              data.rank ? `rank #${formatNumber(data.rank)}` : null,
            ].filter(Boolean);
            status.innerText = `Loaded ${bits.join(" | ")} for ${data.playerId}.`;
          }

          latestCurrentRank = data;
          return data;
        } catch (err) {
          console.error("fetchCurrentRank failed", err);
          if (status) status.innerText = "Could not load current RS right now.";
          return null;
        }
      }

      async function refreshCurrentRank() {
        const currentInput = document.getElementById("current-rs-input");
        const currentRank = await fetchCurrentRank();

        if (!currentRank) return null;

        currentInput.value = currentRank.rankScore ?? "";

        const targetRank = getSelectedTargetRank();
        if (targetRank) {
          await updateRankDisplay(
            targetRank,
            rankThresholds[targetRank],
            currentRank.rankScore ?? 0
          );
        } else {
          const milestone = getNextRankMilestone(currentRank.rankScore);
          if (milestone) {
            await updateRankDisplay(
              milestone.rank,
              milestone.threshold,
              currentRank.rankScore ?? 0,
              milestone.label
            );
          }
        }

        return currentRank;
      }

      async function fetchRubyObject() {
        try {
          const res = await fetch("/api/ruby-status", {
            cache: "no-store",
          });
          if (!res.ok) {
            console.warn("ruby-status returned non-ok", res.status);
            return null;
          }
          const data = await res.json();
          if (data?.rubyRankThreshold) return data.rubyRankThreshold;
          if (
            typeof data?.threshold === "number" ||
            typeof data?.unlocked === "boolean"
          ) {
            return {
              threshold: data.threshold ?? null,
              season: data.season ?? null,
              player: data.player ?? null,
              unlocked: data.unlocked ?? data.threshold != null,
            };
          }
          return null;
        } catch (err) {
          console.error("fetchRubyObject failed", err);
          return null;
        }
      }

      async function updateRankDisplay(
        targetRankRaw,
        targetRSRaw,
        currentRSRaw,
        displayLabel
      ) {
        const goalLabel = document.getElementById("goal-label");
        const rsNeeded = document.getElementById("rs-needed");
        const progressBar = document.getElementById("rank-progress-bar");

        // normalize inputs
        const targetRank = Number(targetRankRaw); // will convert "6" -> 6
        let effectiveTargetRS = parseNumber(targetRSRaw);
        let currentRS = parseNumber(currentRSRaw);

        const rankName = rankNames[targetRank] || "Unknown";
        goalLabel.innerText = displayLabel || rankName;

        if (isNaN(currentRS)) currentRS = 0;

        // If target is Ruby, prefer live cutoff from API
        if (targetRank === 6) {
          if (hasRubyAchievement(latestCurrentRank)) {
            rsNeeded.innerText = "Top 500 already achieved";
            progressBar.style.width = "100%";
            progressBar.style.background = "var(--success)";
            return;
          }

          const ruby = await fetchRubyObject();
          if (ruby && typeof ruby.threshold === "number") {
            effectiveTargetRS = parseNumber(ruby.threshold);
          } else {
            effectiveTargetRS = NaN;
          }
        }

        // safety check
        if (isNaN(effectiveTargetRS) || effectiveTargetRS <= 0) {
          rsNeeded.innerText = "Target unavailable";
          progressBar.style.width = "0%";
          progressBar.style.background = "var(--primary)";
          return;
        }

        const diff = Math.max(0, Math.round(effectiveTargetRS - currentRS));
        if (diff <= 0) {
          rsNeeded.innerText = targetRank === 6 ? "Top 500 already achieved" : "Already achieved";
          progressBar.style.width = "100%";
          progressBar.style.background = "var(--success)";
        } else {
          rsNeeded.innerText = `${formatNumber(diff)} RS needed`;
          const pct = Math.min(
            100,
            Math.max(0, (currentRS / effectiveTargetRS) * 100)
          );
          progressBar.style.width = pct + "%";
          progressBar.style.background = "var(--primary)";
        }
      }

      async function loadRankGoal() {
        try {
          const [goalResult, currentRank] = await Promise.all([
            fetch("/api/my-rank-goal").then((res) => res.json()),
            fetchCurrentRank(),
          ]);
          const data = goalResult;
          const liveRS = currentRank?.rankScore;

          if (data.goal) {
            const {
              targetRank,
              targetRankScore,
              startingRankScore
            } =
            data.goal;

            document.getElementById("target-rank-select").value = targetRank;
            document.getElementById("current-rs-input").value =
              liveRS ?? startingRankScore ?? "";

            await updateRankDisplay(
              targetRank,
              targetRankScore ?? rankThresholds[targetRank],
              liveRS ?? startingRankScore ?? 0
            );
            return;
          }

          if (typeof liveRS === "number") {
            document.getElementById("current-rs-input").value = liveRS;
            const selectedRank = getSelectedTargetRank();
            if (selectedRank) {
              await updateRankDisplay(
                selectedRank,
                rankThresholds[selectedRank],
                liveRS
              );
              return;
            }

            const milestone = getNextRankMilestone(liveRS);
            if (milestone) {
              await updateRankDisplay(
                milestone.rank,
                milestone.threshold,
                liveRS,
                milestone.label
              );
              return;
            }
          }

          // no goal -> reset
          document.getElementById("goal-label").innerText = "No Goal Set";
          document.getElementById("rs-needed").innerText =
            "Set a goal to get started";
          document.getElementById("rank-progress-bar").style.width = "0%";
        } catch (err) {
          console.error("loadRankGoal failed", err);
        }
      }

      async function checkRubyStatus() {
        try {
          const res = await fetch("/api/ruby-status");
          const data = await res.json();

          const rubyInfo = document.getElementById("ruby-info");
          if (!rubyInfo) return;

          // API error case
          if (data.error) {
            rubyInfo.innerHTML = `
            <i class="fas fa-exclamation-triangle" style="color: #dc3545;"></i>
            Unable to load Ruby rank status.
          `;
            return;
          }

          const ruby = data.rubyRankThreshold;

          // If ruby object doesn't exist at all
          if (!ruby) {
            rubyInfo.innerHTML = `
            <i class="fas fa-question-circle" style="color: #6c757d;"></i>
            Top 500 cutoff is currently unavailable.
          `;
            return;
          }

          // Ruby unlocked — threshold exists
          if (typeof ruby.threshold === "number") {
            rubyInfo.innerHTML = `
            <i class="fas fa-info-circle" style="color: #ffc107;"></i>
            <strong>${ruby.unlocked ? "Ruby rank is live." : "Top 500 target"}</strong> Current cutoff:
            <strong>${ruby.threshold.toLocaleString()} RS</strong>.
            <br><small>${ruby.unlocked ? "Reach or beat this score to enter Ruby." : "Ruby is not active yet, so this tracks the score needed to be Top 500."}</small>
          `;
            return;
          }

          // Ruby not unlocked yet
          rubyInfo.innerHTML = `
          <i class="fas fa-lock" style="color: #ffc107;"></i>
          Ruby rank will unlock later in Season ${
            ruby.season ?? "N/A"
          }. Until then, aim for Top 500.
        `;
        } catch (err) {
          console.error("Failed to check Ruby status:", err);

          const rubyInfo = document.getElementById("ruby-info");
          if (rubyInfo) {
            rubyInfo.innerHTML = `
            <i class="fas fa-exclamation-triangle" style="color: #dc3545;"></i>
            Unable to connect to Ruby status service.
          `;
          }
        }
      }

