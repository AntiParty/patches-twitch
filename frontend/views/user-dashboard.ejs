      function updatePreview(cmd, val) {
        const triggerMsg  = document.getElementById("preview-trigger-msg");
        const triggerText = document.getElementById("preview-trigger-text");
        const responseMsg = document.getElementById("preview-response-msg");
        const responseText = document.getElementById("preview-response-text");
        if (!responseMsg || !responseText) return;

        // Show the viewer trigger line
        if (triggerMsg) triggerMsg.style.display = "";
        if (triggerText) triggerText.innerText = `!${cmd}`;

        const mock = cmdMockVars[cmd] || {};
        const isCustom = val && val.trim().length > 0;

        // Use the custom response if set, otherwise show the actual default
        let text = isCustom ? val : (cmdDefaults[cmd] || `(Default response for !${cmd})`);

        // Substitute mock values
        text = text.replace(/\{(\w+)\}/g, (match, v) => mock[v] !== undefined ? mock[v] : match);

        responseText.innerText = text;
        responseText.style.color = isCustom ? "#efeff1" : "#adadb8";
        responseMsg.style.opacity = "1";
      }

      async function saveCommand(cmd) {
        const input = document.getElementById(`input-${cmd}`);
        const val = input.value;
        const btn = input.nextElementSibling;
        const originalText = btn.innerText;

        btn.innerText = "...";
        btn.disabled = true;

        try {
          const res = await fetch("/api/my-commands", {
            method: "POST",
            headers: getCsrfHeaders(),
            body: JSON.stringify({ name: cmd, response: val }),
          });
          const data = await res.json();

          if (data.success) {
            btn.innerText = "Saved";
            showToast(`!${cmd} updated`, "success");
            // Update the Custom/Default badge without re-fetching
            const badge = btn.closest("div[style]").previousElementSibling?.querySelector("span:nth-child(2)");
            setTimeout(() => {
              btn.innerText = originalText;
              btn.disabled = false;
              fetchCommands(); // re-render to update Custom/Default badge
            }, 1200);
          } else {
            showToast(data.error || "Failed", "danger");
            btn.innerText = originalText;
            btn.disabled = false;
          }
        } catch (e) {
          showToast("Error connecting to server", "danger");
          btn.innerText = originalText;
          btn.disabled = false;
        }
      }

      async function resetCommand(cmd) {
        const input = document.getElementById(`input-${cmd}`);
        if (!input) return;

        const confirmed = await showConfirm(
          `Reset !${cmd}`,
          `Remove your custom response for !${cmd}? The bot will use its built-in default.`
        );
        if (!confirmed) return;

        input.value = "";
        updatePreview(cmd, "");

        try {
          const res = await fetch("/api/my-commands", {
            method: "POST",
            headers: getCsrfHeaders(),
            body: JSON.stringify({ name: cmd, response: "" }),
          });
          const data = await res.json();
          if (data.success) {
            showToast(`!${cmd} reset to default`, "success");
            fetchCommands();
          } else {
            showToast(data.error || "Failed to reset", "danger");
          }
        } catch (e) {
          showToast("Error connecting to server", "danger");
        }
      }

      // --- Rank Tracker (Mock) ---
      async function updateRankGoal() {
        const rankSelect = document.getElementById("target-rank-select");
        const currentInput = document.getElementById("current-rs-input");

        const targetRank = Number(rankSelect.value);
        let currentRS = parseNumber(currentInput.value);

        if (!targetRank) {
          showToast("Please select a target rank.", "warning");
          return;
        }
        if (isNaN(currentRS)) {
          const currentRank = await refreshCurrentRank();
          currentRS = currentRank?.rankScore ?? NaN;
        }
        if (currentRS < 0) {
          showToast("Please enter a valid current RS.", "warning");
          return;
        }
        if (isNaN(currentRS)) {
          showToast("Current RS is unavailable. Link your account or enter RS manually.", "warning");
          return;
        }

        // For Ruby, capture live cutoff as saved targetRankScore (if available)
        let targetRankScore = rankThresholds[targetRank];
        if (targetRank === 6) {
          const ruby = await fetchRubyObject();
          if (ruby && typeof ruby.threshold === "number") {
            targetRankScore = parseNumber(ruby.threshold);
          } else {
            showToast("Top 500 cutoff is unavailable right now.", "warning");
            return;
          }
        }

        try {
          const res = await fetch("/api/my-rank-goal", {
            method: "POST",
            headers: getCsrfHeaders(),
            body: JSON.stringify({
              targetRank: targetRank,
              targetRankScore: targetRankScore,
              currentRS: currentRS,
            }),
          });

          const data = await res.json();

          if (data.success) {
            // Immediately update UI using the saved targetRankScore
            updateRankDisplay(targetRank, targetRankScore, currentRS);
            showToast("Rank goal updated!", "success");

            const rsNeeded = document.getElementById("rs-needed");
            rsNeeded.style.color = "var(--success)";
