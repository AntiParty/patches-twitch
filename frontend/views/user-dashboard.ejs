    <div id="toast-container" class="toast-container"></div>

    <div id="confirm-modal" class="confirm-overlay">
      <div class="confirm-modal">
        <div id="confirm-title" class="confirm-title">Confirm Action</div>
        <div id="confirm-body" class="confirm-body">Are you sure you want to proceed?</div>
        <div class="confirm-actions">
          <button id="confirm-cancel" class="btn btn-ghost">Cancel</button>
          <button id="confirm-ok" class="btn btn-primary">Confirm</button>
        </div>
      </div>
    </div>


    <script>
      /* --- UI HELPERS --- */
      function showToast(message, type = 'info') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;
        
        const icons = {
          success: 'fa-check-circle',
          danger: 'fa-exclamation-circle',
          warning: 'fa-exclamation-triangle',
          info: 'fa-info-circle'
        };
        
        toast.innerHTML = `
          <i class="fas ${icons[type]}"></i>
          <span>${message}</span>
        `;
        
        container.appendChild(toast);
        
        setTimeout(() => {
          toast.classList.add('fade-out');
          setTimeout(() => toast.remove(), 300);
        }, 4000);
      }

      function showConfirm(title, body) {
        return new Promise((resolve) => {
          const modal = document.getElementById('confirm-modal');
          const titleEl = document.getElementById('confirm-title');
          const bodyEl = document.getElementById('confirm-body');
          const cancelBtn = document.getElementById('confirm-cancel');
          const okBtn = document.getElementById('confirm-ok');
          
          titleEl.innerText = title;
          bodyEl.innerText = body;
          modal.style.display = 'flex';
          
          const cleanup = (result) => {
            modal.style.display = 'none';
            cancelBtn.removeEventListener('click', onCancel);
            okBtn.removeEventListener('click', onOk);
            resolve(result);
          };
          
          const onCancel = () => cleanup(false);
          const onOk = () => cleanup(true);
          
          cancelBtn.addEventListener('click', onCancel);
          okBtn.addEventListener('click', onOk);
        });
      }

      function getCsrfHeaders() {
        const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
        return {
          'Content-Type': 'application/json',
          'X-CSRF-Token': token
        };
      }

      /* --- CLIENT STATE --- */
      const GS_KEY = "finalsrs_getting_started_seen";


      // --- State ---
      let overlayToken = null;
      let overlayLayoutObj = null;

      // --- On Load ---
      document.addEventListener("DOMContentLoaded", () => {
        (async () => {
          // Fetch overlay token securely via session-authenticated API
          try {
            const tokRes = await fetch("/api/overlay/token");
            if (tokRes.ok) {
              const tokJson = await tokRes.json();
              overlayToken = tokJson.token;
            }
          } catch (e) {
            console.error("Failed to fetch overlay token", e);
          }

          // Initialize Overlay URL (may depend on token)
          updateOverlayUrlDisplay();

          // If we have a token, fetch overlay config
          if (overlayToken) {
            try {
              const cfgRes = await fetch(`/api/overlay/config/${overlayToken}`);
              if (cfgRes.ok) {
                const cfgJson = await cfgRes.json();
                overlayLayoutObj = cfgJson.layout || null;
              }
            } catch (e) {
              console.error("Failed to fetch overlay config", e);
            }
          }

          // Initialize Checkboxes from fetched layout
          if (overlayLayoutObj && overlayLayoutObj.visibility) {
            const v = overlayLayoutObj.visibility;
            if (v.hideName)
              document.getElementById("check-hide-name").checked = true;
            if (v.hideRank)
              document.getElementById("check-hide-rank").checked = true;
            if (v.hideScore)
              document.getElementById("check-hide-score").checked = true;
            if (v.hideWT)
              document.getElementById("check-hide-wt").checked = true;
            if (v.hideSession)
              document.getElementById("check-hide-session").checked = true;
          }
        })();

        if (!localStorage.getItem(GS_KEY)) {
          openGettingStarted();
        }
      });

      function openGettingStarted() {
        document.getElementById("getting-started-modal").style.display = "flex";
      }

      function closeGettingStarted() {
        document.getElementById("getting-started-modal").style.display = "none";
      }

      function finishGettingStarted() {
        localStorage.setItem(GS_KEY, "true");
        closeGettingStarted();
      }

      // --- Overlay Functions ---
      function updateOverlayUrlDisplay() {
        const urlInput = document.getElementById("overlay-url-input");
        if (urlInput) {
          const origin = window.location.origin;
          urlInput.value = `${origin}/overlays/overlay.html?token=${overlayToken}`;
        }
      }

      function copyOverlayUrl() {
        const urlInput = document.getElementById("overlay-url-input");
        urlInput.select();
        document.execCommand("copy");

        const btn = document.querySelector(
          'button[onclick="copyOverlayUrl()"]'
        );
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i>';
        setTimeout(() => (btn.innerHTML = originalHtml), 2000);
      }

      async function saveOverlayConfig() {
        const statusEl = document.getElementById("save-status");
        statusEl.innerText = "Saving...";

        const config = {
          layoutMode: "compact", // Default or fetch from dropdown if added back
          visibility: {
            hideName: document.getElementById("check-hide-name").checked,
            hideRank: document.getElementById("check-hide-rank").checked,
            hideScore: document.getElementById("check-hide-score").checked,
            hideWT: document.getElementById("check-hide-wt").checked,
            hideSession: document.getElementById("check-hide-session").checked,
          },
        };

        try {
          const res = await fetch("/api/overlay/config", {
            method: "POST",
            headers: getCsrfHeaders(),
            body: JSON.stringify(config),
          });

          if (res.ok) {
            statusEl.innerHTML =
              '<span style="color: var(--success);"><i class="fas fa-check"></i> Saved</span>';
            setTimeout(() => (statusEl.innerText = ""), 2000);
          } else {
            statusEl.innerText = "Failed to save.";
            showToast("Failed to save overlay configuration", "danger");
          }
        } catch (e) {
          console.error(e);
          statusEl.innerText = "Error saving config.";
          showToast("Error connecting to server", "danger");
        }
      }

      async function regenerateOverlayToken() {
        const confirmed = await showConfirm(
          "Regenerate Token",
          "Regenerating a new token will break your existing overlay links. Continue?"
        );
        if (!confirmed) return;

        const btn = document.querySelector(
          'button[onclick="regenerateOverlayToken()"]'
        );
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating...';

        try {
          const res = await fetch("/api/overlay/regenerate-token", {
            method: "POST",
            headers: getCsrfHeaders(),
          });
          const data = await res.json();

          if (data.token) {
            overlayToken = data.token;
            updateOverlayUrlDisplay();
            showToast("New overlay token generated!", "success");
          } else {
            showToast(data.error || "Failed to regenerate token", "danger");
          }
        } catch (e) {
          showToast("Failed to regenerate token.", "danger");
        } finally {
          btn.disabled = false;
          btn.innerHTML = originalHtml;
        }
      }

      const rankNames = {
        1: "Bronze",

        2: "Silver",
        3: "Gold",
        4: "Platinum",
        5: "Diamond",
        6: "Ruby",
      };
      const rankThresholds = {
        1: 0, // Bronze
        2: 10000, // Silver
        3: 25000, // Gold
        4: 40000, // Platinum
        5: 55000, // Diamond
        6: 75000, // Ruby
      };
      // --- Navigation ---
      function switchView(viewId) {
        document
          .querySelectorAll(".nav-item")
          .forEach((el) => el.classList.remove("active"));

        const map = {
          overview: 0,
          commands: 1,
          "rank-tracker": 2,
          overlays: 3,
          settings: 4,
        };

        const navItems = document.querySelectorAll(".nav-item");
        if (navItems[map[viewId]])
          navItems[map[viewId]].classList.add("active");

        document
          .querySelectorAll(".view-section")
          .forEach((el) => el.classList.remove("active"));
        document.getElementById(`view-${viewId}`).classList.add("active");

        if (viewId === "commands") fetchCommands();
        if (viewId === "rank-tracker") loadRankGoal();
      }

      // --- Commands & Preview ---
      async function fetchCommands() {
        const list = document.getElementById("commands-list");
        list.innerHTML =
          '<div style="text-align: center; padding: 20px; color: var(--text-muted);">Loading...</div>';

        try {
          const res = await fetch("/api/my-commands");
          const data = await res.json();

          if (!data.commands) {
            list.innerHTML =
              '<div style="text-align: center;">No commands found</div>';
            return;
          }

          const allowed = ["rank", "record", "peak"];
          let html = "";

          for (const cmd of allowed) {
            const found = data.commands.find((c) => c.name === cmd);
            const val = found ? found.response : "";
            html += `
             <div style="background: var(--bg-hover); padding: 16px; border-radius: var(--radius); border: 1px solid var(--border);">
               <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                 <span style="font-weight: 600; color: var(--primary);">!${cmd}</span>
                 <span style="font-size: 12px; color: var(--text-muted);">Custom Response</span>
               </div>
               <div style="display: flex; gap: 10px;">
                 <input id="input-${cmd}" class="input" value="${val}" placeholder="Enter response..." oninput="updatePreview('${cmd}', this.value)" onfocus="updatePreview('${cmd}', this.value)">
                 <button class="btn btn-success btn-sm" onclick="saveCommand('${cmd}')">Save</button>
               </div>
             </div>
           `;
          }
          list.innerHTML = html;
        } catch (e) {
          list.innerHTML =
            '<div style="color: var(--danger); text-align: center;">Failed to load commands</div>';
        }
      }

      /* --- helpers --- */
      function parseNumber(value) {
        if (value == null) return NaN;
        if (typeof value === "number") return value;
        const n = Number(String(value).replace(/[^0-9.-]+/g, ""));
        return isNaN(n) ? NaN : n;
      }
      function formatNumber(n) {
        return Number(n).toLocaleString();
      }

      async function fetchRubyObject() {
        try {
          const res = await fetch("/api/ruby-status", { cache: "no-store" });
          if (!res.ok) {
            console.warn("ruby-status returned non-ok", res.status);
            return null;
          }
          const data = await res.json();
          // support both shapes:
          // { rubyRankThreshold: { threshold, season, player } }
          // or { unlocked: true, threshold: 47893, season: 8 }
          if (data?.rubyRankThreshold) return data.rubyRankThreshold;
          if (
            typeof data?.threshold === "number" ||
            typeof data?.unlocked === "boolean"
          ) {
            return {
              threshold: data.threshold ?? null,
              season: data.season ?? null,
              player: data.player ?? null,
              unlocked: data.unlocked ?? data.threshold != null,
            };
          }
          return null;
        } catch (err) {
          console.error("fetchRubyObject failed", err);
          return null;
        }
      }

      async function updateRankDisplay(
        targetRankRaw,
        targetRSRaw,
        currentRSRaw
      ) {
        const goalLabel = document.getElementById("goal-label");
        const rsNeeded = document.getElementById("rs-needed");
        const progressBar = document.getElementById("rank-progress-bar");

        // normalize inputs
        const targetRank = Number(targetRankRaw); // will convert "6" -> 6
        let effectiveTargetRS = parseNumber(targetRSRaw);
        let currentRS = parseNumber(currentRSRaw);

        const rankName = rankNames[targetRank] || "Unknown";
        goalLabel.innerText = `${rankName} 1`;

        if (isNaN(currentRS)) currentRS = 0;

        // If target is Ruby, prefer live cutoff from API
        if (targetRank === 6) {
          const ruby = await fetchRubyObject();
          console.log("DEBUG: fetched ruby object:", ruby);
          if (ruby && typeof ruby.threshold === "number") {
            effectiveTargetRS = parseNumber(ruby.threshold);
          } else {
            console.warn(
              "DEBUG: live Ruby threshold unavailable, falling back to static value."
            );
            effectiveTargetRS = parseNumber(rankThresholds[6]);
          }
        }

        // safety check
        if (isNaN(effectiveTargetRS) || effectiveTargetRS <= 0) {
          rsNeeded.innerText = "Target unavailable";
          progressBar.style.width = "0%";
          progressBar.style.background = "var(--primary)";
          return;
        }

        const diff = Math.max(0, Math.round(effectiveTargetRS - currentRS));
        if (diff <= 0) {
          rsNeeded.innerText = "Goal Reached!";
          progressBar.style.width = "100%";
          progressBar.style.background = "var(--success)";
        } else {
          rsNeeded.innerText = `${formatNumber(diff)} RS needed`;
          const pct = Math.min(
            100,
            Math.max(0, (currentRS / effectiveTargetRS) * 100)
          );
          progressBar.style.width = pct + "%";
          progressBar.style.background = "var(--primary)";
        }
      }

      async function loadRankGoal() {
        try {
          const res = await fetch("/api/my-rank-goal");
          const data = await res.json();

          if (data.goal) {
            const { targetRank, targetRankScore, startingRankScore } =
              data.goal;

            document.getElementById("target-rank-select").value = targetRank;
            document.getElementById("current-rs-input").value =
              startingRankScore ?? "";

            // pass saved score (may be null) and current RS, updateRankDisplay will replace for Ruby
            await updateRankDisplay(
              targetRank,
              targetRankScore ?? rankThresholds[targetRank],
              startingRankScore ?? 0
            );
            return;
          }

          // no goal -> reset
          document.getElementById("goal-label").innerText = "No Goal Set";
          document.getElementById("rs-needed").innerText =
            "Set a goal to get started";
          document.getElementById("rank-progress-bar").style.width = "0%";
        } catch (err) {
          console.error("loadRankGoal failed", err);
        }
      }

      async function checkRubyStatus() {
        try {
          const res = await fetch("/api/ruby-status");
          const data = await res.json();

          const rubyInfo = document.getElementById("ruby-info");
          if (!rubyInfo) return;

          // API error case
          if (data.error) {
            rubyInfo.innerHTML = `
        <i class="fas fa-exclamation-triangle" style="color: #dc3545;"></i>
        Unable to load Ruby rank status.
      `;
            return;
          }

          const ruby = data.rubyRankThreshold;

          // If ruby object doesn't exist at all
          if (!ruby) {
            rubyInfo.innerHTML = `
        <i class="fas fa-question-circle" style="color: #6c757d;"></i>
        Ruby status is currently unavailable.
      `;
            return;
          }

          // Ruby unlocked — threshold exists
          if (typeof ruby.threshold === "number") {
            rubyInfo.innerHTML = `
        <i class="fas fa-info-circle" style="color: #ffc107;"></i>
        <strong>Ruby rank is live!</strong> Current Top 500 cutoff:
        <strong>${ruby.threshold.toLocaleString()} RS</strong>.
        <br><small>Updates every 45 minutes as players compete.</small>
      `;
            return;
          }

          // Ruby not unlocked yet
          rubyInfo.innerHTML = `
      <i class="fas fa-lock" style="color: #ffc107;"></i>
      Ruby rank will unlock later in Season ${
        ruby.season ?? "N/A"
      }. Check back soon!
    `;
        } catch (err) {
          console.error("Failed to check Ruby status:", err);

          const rubyInfo = document.getElementById("ruby-info");
          if (rubyInfo) {
            rubyInfo.innerHTML = `
        <i class="fas fa-exclamation-triangle" style="color: #dc3545;"></i>
        Unable to connect to Ruby status service.
      `;
          }
        }
      }

      async function loadOverlayToken() {
        try {
          const response = await fetch("/api/overlay/token");
          const data = await response.json();
          overlayToken = data.token;

          const overlayUrl = `${window.location.origin}/overlays/minimal.html?token=${overlayToken}`;
          const urlEl = document.getElementById("overlay-url-input");
          const previewEl = document.getElementById("overlay-preview");
          if (urlEl) urlEl.value = overlayUrl;
          if (previewEl) previewEl.src = overlayUrl;

          // Load current config
          await loadOverlayConfig();
        } catch (error) {
          console.error("Failed to load overlay token:", error);
          const urlEl =
            document.getElementById("overlay-url") ||
            document.getElementById("overlay-url-input");
          if (urlEl) urlEl.value = "Error loading token";
        }
      }

      async function loadOverlayConfig() {
        if (!overlayToken) return;

        try {
          const response = await fetch(`/api/overlay/config/${overlayToken}`);
          const config = await response.json();

          if (config) {
            document.getElementById("overlay-theme").value = config.theme;
            document.getElementById("overlay-color").value =
              config.primaryColor;
            document.getElementById("overlay-layout").value = config.layout;
          }
        } catch (error) {
          console.error("Failed to load overlay config:", error);
        }
      }

      function copyOverlayURL() {
        const input = document.getElementById("overlay-url");
        input.select();
        input.setSelectionRange(0, 99999); // For mobile
        document.execCommand("copy");

        // Visual feedback
        const btn = event.target.closest("button");
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
        setTimeout(() => {
          btn.innerHTML = originalText;
        }, 2000);
      }

      // (Duplicates removed: regenerateOverlayToken is now consolidated)

      function updateOverlayPreview() {
        // Refresh the iframe to show changes
        const iframe = document.getElementById("overlay-preview");
        iframe.src = iframe.src;
      }

      async function resetSession() {
        const confirmed = await showConfirm(
          "Reset Session",
          "Reset your session tracker? This will set your session start RS to your current RS."
        );
        if (!confirmed) return;

        try {
          const response = await fetch("/api/overlay/reset-session", {
            method: "POST",
            headers: getCsrfHeaders(),
          });
          const data = await response.json();

          showToast(`Session reset! Starting RS: ${data.sessionRS.toLocaleString()}`, "success");
          updateOverlayPreview();
        } catch (error) {
          showToast("Failed to reset session", "danger");
        }
      }

      const mockVars = {
        username: "<%= username %>",
        user: "<%= username %>",
        rank: "#123",
        league: "Diamond 1",
        rankScore: "45,210",
        score: "45,210",
        wtRank: "#456",
        found: "true",
      };

      function updatePreview(cmd, val) {
        const previewMsg = document.getElementById("preview-response-msg");
        const content = previewMsg.querySelector(".msg-content");
        const user = previewMsg.querySelector(".user-name");
        const viewerName = document.querySelector(".chat-msg .user-name");

        // Update the user message to match the command (!rank, !record, etc)
        const userMsgs = document.querySelectorAll(".chat-msg .msg-content");
        if (userMsgs.length >= 2) {
          userMsgs[1].innerText = `!${cmd}`;
        }

        let responseText =
          val ||
          (cmd === "rank"
            ? "Your rank is {rankScore} RS in {league} | WT rank: {wtRank}"
            : `(Default response for !${cmd})`);

        // Replace variables with mock data
        responseText = responseText.replace(/\{(\w+)\}/g, (match, v) => {
          return mockVars[v] || match;
        });

        user.innerText = "FinalsRS";
        content.innerText = responseText;
        content.style.fontSize = "13px";
        content.style.color = val ? "#efeff1" : "#adadb8";
        previewMsg.style.opacity = "1";
      }

      async function saveCommand(cmd) {
        const input = document.getElementById(`input-${cmd}`);
        const val = input.value;
        const btn = input.nextElementSibling;
        const originalText = btn.innerText;

        btn.innerText = "...";
        btn.disabled = true;

        try {
          const res = await fetch("/api/my-commands", {
            method: "POST",
            headers: getCsrfHeaders(),
            body: JSON.stringify({ name: cmd, response: val }),
          });
          const data = await res.json();

          if (data.success) {
            btn.innerText = "Saved";
            showToast(`Command !${cmd} updated`, "success");
            setTimeout(() => {
              btn.innerText = originalText;
              btn.disabled = false;
            }, 2000);
          } else {
            showToast(data.error || "Failed", "danger");
            btn.innerText = originalText;
            btn.disabled = false;
          }
        } catch (e) {
          showToast("Error connecting to server", "danger");
          btn.innerText = originalText;
          btn.disabled = false;
        }
      }

      // --- Rank Tracker (Mock) ---
      async function updateRankGoal() {
        const rankSelect = document.getElementById("target-rank-select");
        const currentInput = document.getElementById("current-rs-input");

        const targetRank = Number(rankSelect.value);
        const currentRS = parseNumber(currentInput.value) || 0;

        if (!targetRank) {
          showToast("Please select a target rank.", "warning");
          return;
        }
        if (currentRS < 0) {
          showToast("Please enter a valid current RS.", "warning");
          return;
        }

        // For Ruby, capture live cutoff as saved targetRankScore (if available)
        let targetRankScore = rankThresholds[targetRank] ?? 0;
        if (targetRank === 6) {
          const ruby = await fetchRubyObject();
          if (ruby && typeof ruby.threshold === "number")
            targetRankScore = parseNumber(ruby.threshold);
        }

        try {
          const res = await fetch("/api/my-rank-goal", {
            method: "POST",
            headers: getCsrfHeaders(),
            body: JSON.stringify({
              targetRank: targetRank,
              targetRankScore: targetRankScore,
              startingRankScore: currentRS,
            }),
          });

          const data = await res.json();

          if (data.success) {
            // Immediately update UI using the saved targetRankScore
            updateRankDisplay(targetRank, targetRankScore, currentRS);
            showToast("Rank goal updated!", "success");

            const rsNeeded = document.getElementById("rs-needed");
            rsNeeded.style.color = "var(--success)";
            setTimeout(() => {
              rsNeeded.style.color = "";
              updateRankDisplay(targetRank, targetRankScore, currentRS);
            }, 1500);
          } else {
            showToast(data.error || "Failed to update goal.", "danger");
          }
        } catch (err) {
          console.error("Error updating rank goal:", err);
          showToast("Error connecting to server", "danger");
        }
      }

      async function deleteRankGoal() {
        const confirmed = await showConfirm(
          "Delete Goal",
          "Are you sure you want to delete your rank goal?"
        );
        if (!confirmed) return;

        try {
          const res = await fetch("/api/my-rank-goal", {
            method: "DELETE",
            headers: getCsrfHeaders(),
          });

          const data = await res.json();

          if (data.success) {
            // Reset form
            document.getElementById("target-rank-select").value = "";
            document.getElementById("current-rs-input").value = "";
            document.getElementById("goal-label").innerText = "No Goal Set";
            document.getElementById("rs-needed").innerText =
              "Set a goal to get started";
            document.getElementById("rank-progress-bar").style.width = "0%";

            showToast("Rank goal deleted successfully.", "success");
          } else {
            showToast(data.error || "Failed to delete goal.", "danger");
          }
        } catch (err) {
          console.error("Error deleting rank goal:", err);
          showToast("Error connecting to server", "danger");
        }
      }

      // --- Account Linking ---
      document.addEventListener("DOMContentLoaded", () => {
        const linkAccountBtn = document.getElementById("link-account-btn");
        if (linkAccountBtn) {
          linkAccountBtn.addEventListener("click", async function () {
            const input = document.getElementById("player-id-input");
            const status = document.getElementById("link-status");
            const btn = this;

            if (!input.value) return;

            btn.disabled = true;
            btn.innerText = "Saving...";
            status.innerHTML = "";

            try {
              const res = await fetch("/api/link-account", {
                method: "POST",
                headers: getCsrfHeaders(),
                body: JSON.stringify({ playerId: input.value }),
              });
              const data = await res.json();

              if (data.success) {
                status.innerHTML =
                  '<span style="color:var(--success)">Successfully linked! Reloading...</span>';
                setTimeout(() => window.location.reload(), 1000);
              } else {
                status.innerHTML = `<span style="color:var(--danger)">${
                  data.error || "Failed"
                }</span>`;
                btn.disabled = false;
                btn.innerText = "Save";
              }
            } catch (e) {
              status.innerHTML =
                '<span style="color:var(--danger)">Error connecting to server</span>';
              btn.disabled = false;
              btn.innerText = "Save";
            }
          });
        }

        const targetRankSelect = document.getElementById("target-rank-select");
        if (targetRankSelect) {
          targetRankSelect.addEventListener("change", async function () {
            const sel = Number(this.value);
            const rubyInfo = document.getElementById("ruby-info");

            if (sel === 6) {
              if (rubyInfo) rubyInfo.style.display = "block";
            } else {
              if (rubyInfo) rubyInfo.style.display = "none";
            }

            const currentInputVal =
              parseNumber(document.getElementById("current-rs-input").value) ||
              0;
            const fallbackTarget = rankThresholds[sel] ?? 0;
            await updateRankDisplay(sel, fallbackTarget, currentInputVal);
          });
        }

        // --- Disconnect ---
        const disconnectBtn = document.getElementById("disconnect-btn");
        if (disconnectBtn) {
          disconnectBtn.addEventListener("click", async function () {
            const confirmed = await showConfirm(
              "Disconnect Bot",
              "Are you sure? This will remove the bot from your channel."
            );
            if (!confirmed) return;

            const btn = this;
            btn.disabled = true;
            btn.innerText = "Disconnecting...";

            try {
              const res = await fetch("/api/disconnect-bot", {
                method: "POST",
                headers: getCsrfHeaders(),
              });
              const data = await res.json();

              if (data.success) {
                showToast("Disconnected successfully.", "success");
                setTimeout(() => window.location.href = "/", 1000);
              } else {
                showToast(data.error || "Failed", "danger");
                btn.disabled = false;
                btn.innerText = "Disconnect Bot";
              }
            } catch (e) {
              showToast("Error connecting to server", "danger");
              btn.disabled = false;
              btn.innerText = "Disconnect Bot";
            }

          });
        }
      });

      async function toggleBot() {
        const btn = document.getElementById("toggle-bot-btn");
        const text = document.getElementById("toggle-bot-text");
        const icon = document.getElementById("toggle-bot-icon");
        const statusText = document.getElementById("bot-status-text");
        const statusSubtitle = document.getElementById("bot-status-subtitle");
        const indicator = document.getElementById("bot-status-indicator");

        const originalText = text.innerText;
        text.innerText = "Wait...";
        btn.disabled = true;

        try {
          const res = await fetch("/api/toggle-bot", {
            method: "POST",
            headers: getCsrfHeaders(),
          });
          const data = await res.json();

          if (data.success) {
            const isEnabled = data.bot_enabled;

            // Update Button
            btn.className = `btn ${
              isEnabled ? "btn-danger-solid" : "btn-success-solid"
            }`;
            text.innerText = isEnabled ? "Turn Off" : "Turn On";
            icon.className = `fas ${isEnabled ? "fa-power-off" : "fa-play"}`;

            // Update Status Display
            statusText.innerText = isEnabled ? "Active" : "Inactive";
            statusSubtitle.innerText = isEnabled
              ? "Connected to chat"
              : "Bot is currently offline";

            indicator.className = isEnabled
              ? "indicator-success"
              : "indicator-danger";

            showToast(`Bot turned ${isEnabled ? 'on' : 'off'}`, "success");
            btn.disabled = false;
          } else {
            showToast("Failed to toggle bot status.", "danger");
            text.innerText = originalText;
            btn.disabled = false;
          }
        } catch (err) {
          console.error("Error toggling bot:", err);
          showToast("An error occurred. Please try again.", "danger");
          text.innerText = originalText;
          btn.disabled = false;
        }

      }
    </script>
  </body>
</html>