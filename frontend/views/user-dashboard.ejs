      function addPredictionAutomationOutcome(outcome = {}) {
        const list = document.getElementById("prediction-automation-outcomes");
        if (!list || list.children.length >= 5) return;
        const row = predictionElement("div", "prediction-outcome-row");
        row.style.gridTemplateColumns = "minmax(150px, 1fr) minmax(90px, .55fr) minmax(90px, .55fr) 40px";

        const label = predictionElement("input", "input");
        label.maxLength = 25;
        label.required = true;
        label.placeholder = "Outcome label";
        label.value = outcome.label || "";
        label.dataset.autoOutcomeLabel = "true";

        const minimum = predictionElement("input", "input");
        minimum.type = "number";
        minimum.step = "1";
        minimum.placeholder = "Min";
        minimum.value = outcome.minDelta === null || outcome.minDelta === undefined
          ? ""
          : String(outcome.minDelta);
        minimum.dataset.autoOutcomeMin = "true";

        const maximum = predictionElement("input", "input");
        maximum.type = "number";
        maximum.step = "1";
        maximum.placeholder = "Max";
        maximum.value = outcome.maxDelta === null || outcome.maxDelta === undefined
          ? ""
          : String(outcome.maxDelta);
        maximum.dataset.autoOutcomeMax = "true";

        const remove = predictionElement("button", "btn btn-ghost prediction-icon-button");
        remove.type = "button";
        remove.setAttribute("aria-label", "Remove automatic prediction outcome");
        const icon = predictionElement("i");
        icon.className = "fas fa-xmark";
        remove.appendChild(icon);
        remove.addEventListener("click", () => {
          if (list.children.length <= 2) {
            showToast("Automatic predictions need at least two outcomes.", "warning");
            return;
          }
          row.remove();
          refreshPredictionAutomationOutcomeButton();
        });

        row.append(label, minimum, maximum, remove);
        list.appendChild(row);
        refreshPredictionAutomationOutcomeButton();
      }

      function refreshPredictionAutomationOutcomeButton() {
        const list = document.getElementById("prediction-automation-outcomes");
        const button = document.getElementById("prediction-automation-add-outcome");
        if (list && button) button.disabled = list.children.length >= 5;
      }

