          </div>

          <div class="grid-2">
            <!-- Premium Status -->
            <div class="status-card">
              <div class="card-title">Premium Status</div>
              <% if (hasSubscription) { %>
              <div class="status-info">
                <div class="status-item">
                  <span class="label">Status:</span>
                  <span class="value" style="color: var(--success);">Active</span>
                </div>
                <% if (hasTwitchSub) { %>
                <div class="status-item">
