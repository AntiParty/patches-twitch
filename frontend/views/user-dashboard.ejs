        document.getElementById("prediction-automation-delay").value = String(data.config.startDelaySeconds);
        document.getElementById("prediction-automation-window").value = String(data.config.votingWindowSeconds);
        document.getElementById("prediction-automation-question").value = data.config.question || "";
        const list = document.getElementById("prediction-automation-outcomes");
        list.replaceChildren();
        (data.config.outcomes || []).forEach((outcome) => addPredictionAutomationOutcome(outcome));
