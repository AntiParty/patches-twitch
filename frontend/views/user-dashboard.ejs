      async function checkOnboardingProgress() {
        // Check step 1: Bot enabled
        try {
          // Check bot status by looking at the status indicator or text
          const statusText = document.getElementById("bot-status-text");
          const indicator = document.getElementById("bot-status-indicator");
          const botEnabled =
            (statusText &&
              statusText.innerText.trim().toLowerCase() === "active") ||
            (indicator && indicator.classList.contains("indicator-success"));
          updateStepStatus(1, botEnabled);
        } catch (e) {
          console.error("Failed to check bot status", e);
        }

        // Check step 2: Account linked
        try {
          // Check multiple sources for account link status
          const playerIdInput = document.getElementById("player-id-input");
          const playerIdFromInput = playerIdInput ?
            playerIdInput.value.trim() :
            "";

          // Check if the linked account card shows a player ID (not "No Account Linked")
          const linkedAccountSection = document.querySelector(
            "#view-overview .grid-3 .card:nth-child(2)"
          );
          const hasLinkedAccountInCard =
            linkedAccountSection &&
            !linkedAccountSection.textContent.includes("No Account Linked") &&
            linkedAccountSection.textContent.includes("Tracking stats");

          const hasLinkedAccount =
            playerIdFromInput !== "" || hasLinkedAccountInCard;
          updateStepStatus(2, hasLinkedAccount);
        } catch (e) {
          console.error("Failed to check account link status", e);
        }

        // Check step 3: Commands customized (optional, always show as optional)
        // This is optional, so we don't mark it as required
        updateStepStatus(3, false, true);

        // Check step 4: Overlay setup (optional, always show as optional)
        // Check if overlay token exists and URL is set
        const overlayUrlInput = document.getElementById("overlay-url-input");
        const hasOverlaySetup =
          (overlayToken && overlayToken.trim() !== "") ||
          (overlayUrlInput &&
            overlayUrlInput.value &&
            overlayUrlInput.value !== "");
        updateStepStatus(4, hasOverlaySetup, true);
      }

      function updateStepStatus(step, completed, optional = false) {
        const icon = document.getElementById(`gs-icon-${step}`);
        const action = document.getElementById(`gs-action-${step}`);
        const status = document.getElementById(`gs-status-${step}`);
        const checklistItem = document.getElementById(`checklist-item-${step}`);

        if (completed) {
          icon.classList.add("completed");
          icon.innerHTML = '<i class="fas fa-check"></i>';
          action.classList.add("completed");
          status.innerText = "Completed";
          status.style.background = "var(--success)";
          status.style.color = "white";
          if (checklistItem) {
            checklistItem.classList.add("completed");
            const checkIcon = checklistItem.querySelector(
              ".onboarding-checklist-item-icon i"
            );
            if (checkIcon) checkIcon.style.display = "block";
          }
        } else {
          icon.classList.remove("completed");
          action.classList.remove("completed");
          if (optional) {
            status.innerText = "Optional";
            status.style.background = "var(--bg-app)";
            status.style.color = "var(--text-muted)";
          } else {
            status.innerText = "Pending";
            status.style.background = "var(--bg-app)";
            status.style.color = "var(--text-muted)";
          }
          if (checklistItem) {
            checklistItem.classList.remove("completed");
            const checkIcon = checklistItem.querySelector(
              ".onboarding-checklist-item-icon i"
            );
            if (checkIcon) checkIcon.style.display = "none";
          }
        }
      }

      function showOnboardingChecklist() {
        const checklist = document.getElementById("onboarding-checklist");
        const checklistHidden = localStorage.getItem(GS_CHECKLIST_KEY);
        const onboardingCompleted = localStorage.getItem(GS_COMPLETED_KEY);

        if (!checklistHidden && !onboardingCompleted) {
          checklist.style.display = "block";
          checkOnboardingProgress();
        }
      }

      function hideOnboardingChecklist() {
        const checklist = document.getElementById("onboarding-checklist");
        checklist.style.display = "none";
        localStorage.setItem(GS_CHECKLIST_KEY, "true");
      }

      // --- On Load ---
      document.addEventListener("DOMContentLoaded", () => {
        (async () => {
          // Handle URL Params for View Switching and Alerts
          const urlParams = new URLSearchParams(window.location.search);
          const viewParam = urlParams.get('view');
          if (viewParam && ['overview', 'commands', 'rank-tracker', 'overlays', 'analytics', 'subscription', 'settings'].includes(viewParam)) {
              // slight delay to ensure everything is initialized
              setTimeout(() => switchView(viewParam), 100);
          }

          const errorParam = urlParams.get("error");
          const successParam = urlParams.get("success");
          
          if (errorParam) {
              let msg = "An error occurred.";
              if (errorParam === 'missing_params') msg = "Missing parameters.";
              if (errorParam === 'invalid_state') msg = "Invalid session state. Please try again.";
              if (errorParam === 'bot_already_linked') msg = "This bot account is already linked to another user.";
              if (errorParam === 'oauth_failed') msg = "OAuth authorization failed.";
              // Remove param from URL without refresh to avoid showing toast on reload
              window.history.replaceState({}, document.title, window.location.pathname + (viewParam ? `?view=${viewParam}` : ''));
              setTimeout(() => showToast(msg, "danger"), 500);
          }

          if (successParam) {
               let msg = "Operation successful.";
               if (successParam === 'bot_linked') msg = "Custom bot linked successfully!";
               window.history.replaceState({}, document.title, window.location.pathname + (viewParam ? `?view=${viewParam}` : ''));
               setTimeout(() => showToast(msg, "success"), 500);
          }

          // Fetch overlay token securely via session-authenticated API
          try {
            const tokRes = await fetch("/api/overlay/token");
            if (tokRes.ok) {
              const tokJson = await tokRes.json();
              overlayToken = tokJson.token;
            }
          } catch (e) {
            console.error("Failed to fetch overlay token", e);
          }

          // Initialize Overlay URL (may depend on token)
          updateOverlayUrlDisplay();

          // If we have a token, fetch overlay config
          if (overlayToken) {
            try {
              const cfgRes = await fetch(`/api/overlay/config/${overlayToken}`);
              if (cfgRes.ok) {
                const cfgJson = await cfgRes.json();
                overlayLayoutObj = cfgJson.layout || null;

                // Initialize new inputs
                if (cfgJson.theme) {
                  const themeSelect = document.getElementById(
                    "overlay-theme-select"
                  );
                  if (themeSelect) themeSelect.value = cfgJson.theme;
                }
                if (cfgJson.primaryColor) {
                  const colorInput = document.getElementById(
                    "overlay-color-input"
                  );
                  if (colorInput) {
                    colorInput.value = cfgJson.primaryColor;
                    document.getElementById("color-value").innerText =
                      cfgJson.primaryColor.toUpperCase();
                  }
                }
                if (overlayLayoutObj && overlayLayoutObj.mode) {
                  const layoutSelect = document.getElementById(
                    "overlay-layout-select"
                  );
                  if (layoutSelect) layoutSelect.value = overlayLayoutObj.mode;
                }
              }
            } catch (e) {
              console.error("Failed to fetch overlay config", e);
            }
          }

          // Initialize Visibility from fetched layout
          if (overlayLayoutObj && overlayLayoutObj.visibility) {
            const v = overlayLayoutObj.visibility;
            if (v.hideName)
              document.getElementById("check-hide-name").checked = true;
            if (v.hideRank)
              document.getElementById("check-hide-rank").checked = true;
            if (v.hideScore)
              document.getElementById("check-hide-score").checked = true;
            if (v.hideSession)
              document.getElementById("check-hide-session").checked = true;
          }

          // Final refresh of preview once everything is set
          updateOverlayUrlDisplay();
        })();

        // Initialize onboarding
        if (!localStorage.getItem(GS_KEY)) {
          openGettingStarted();
        } else {
          showOnboardingChecklist();
        }

        // Check progress periodically
        setInterval(checkOnboardingProgress, 5000);
      });

      // --- Overlay Functions ---
      function updateOverlayUrlDisplay() {
        const urlInput = document.getElementById("overlay-url-input");
        const iframe = document.getElementById("overlay-preview-iframe");
        const themeSelect = document.getElementById("overlay-theme-select");

        if (urlInput) {
          const origin = window.location.origin;
          const theme = themeSelect ? themeSelect.value : "minimal";
          const overlayFile = `${theme}.html`;

          const url = `${origin}/overlays/${overlayFile}?token=${overlayToken}&preview=true&t=${Date.now()}`;
          urlInput.value = `${origin}/overlays/${overlayFile}?token=${overlayToken}`;
          if (iframe) iframe.src = url;
        }
      }

      function copyOverlayUrl() {
        const urlInput = document.getElementById("overlay-url-input");
        urlInput.select();
        document.execCommand("copy");

        const btn = document.querySelector(
          'button[onclick="copyOverlayUrl()"]'
        );
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i>';
        setTimeout(() => (btn.innerHTML = originalHtml), 2000);
      }

      let saveTimeout = null;
      async function saveOverlayConfig() {
        const statusEl = document.getElementById("save-status");
        statusEl.innerText = "Saving...";

        // Update color value text
        const colorInput = document.getElementById("overlay-color-input");
        if (colorInput) {
          document.getElementById("color-value").innerText =
            colorInput.value.toUpperCase();
        }

        const config = {
          theme: document.getElementById("overlay-theme-select").value,
          primaryColor: document.getElementById("overlay-color-input").value,
          layoutMode: document.getElementById("overlay-layout-select").value,
          visibility: {
            hideName: document.getElementById("check-hide-name").checked,
            hideRank: document.getElementById("check-hide-rank").checked,
            hideScore: document.getElementById("check-hide-score").checked,
            hideSession: document.getElementById("check-hide-session").checked,
          },
        };

        try {
          const res = await fetch("/api/overlay/config", {
            method: "POST",
            headers: getCsrfHeaders(),
            body: JSON.stringify(config),
          });

          if (res.ok) {
            statusEl.innerHTML =
              '<span style="color: var(--success);"><i class="fas fa-check"></i> Saved</span>';
            setTimeout(() => (statusEl.innerText = ""), 2000);

            // Refresh preview after a small delay to allow server to update
            if (saveTimeout) clearTimeout(saveTimeout);
            saveTimeout = setTimeout(() => {
              updateOverlayUrlDisplay();
            }, 500);
          } else {
            statusEl.innerText = "Failed to save.";
            showToast("Failed to save overlay configuration", "danger");
          }
        } catch (e) {
          console.error(e);
          statusEl.innerText = "Error saving config.";
          showToast("Error connecting to server", "danger");
        }
      }

      async function regenerateOverlayToken() {
        const confirmed = await showConfirm(
          "Regenerate Token",
          "Regenerating a new token will break your existing overlay links. Continue?"
        );
        if (!confirmed) return;

        const btn = document.querySelector(
          'button[onclick="regenerateOverlayToken()"]'
        );
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating...';

        try {
          const res = await fetch("/api/overlay/regenerate-token", {
            method: "POST",
            headers: getCsrfHeaders(),
          });
          const data = await res.json();

          if (data.token) {
            overlayToken = data.token;
            updateOverlayUrlDisplay();
            showToast("New overlay token generated!", "success");
          } else {
            showToast(data.error || "Failed to regenerate token", "danger");
          }
        } catch (e) {
          showToast("Failed to regenerate token.", "danger");
        } finally {
          btn.disabled = false;
          btn.innerHTML = originalHtml;
        }
      }

      const rankNames = {
