          });
        }

        const targetRankSelect = document.getElementById("target-rank-select");
        if (targetRankSelect) {
          targetRankSelect.addEventListener("change", async function () {
            const sel = Number(this.value);
            const rubyInfo = document.getElementById("ruby-info");

            if (sel === 6) {
              if (rubyInfo) rubyInfo.style.display = "block";
            } else {
              if (rubyInfo) rubyInfo.style.display = "none";
            }

            const currentInputVal =
              parseNumber(document.getElementById("current-rs-input").value) ||
              0;
            const fallbackTarget = rankThresholds[sel] ?? 0;
            await updateRankDisplay(sel, fallbackTarget, currentInputVal);
          });
        }

        // --- Disconnect ---
        const disconnectBtn = document.getElementById("disconnect-btn");
        if (disconnectBtn) {
          disconnectBtn.addEventListener("click", async function () {
            const confirmed = await showConfirm(
              "Disconnect Bot",
              "Are you sure? This will remove the bot from your channel."
            );
            if (!confirmed) return;

            const btn = this;
            btn.disabled = true;
            btn.innerText = "Disconnecting...";

            try {
              const res = await fetch("/api/disconnect-bot", {
                method: "POST",
                headers: getCsrfHeaders(),
              });
              const data = await res.json();

              if (data.success) {
                showToast("Disconnected successfully.", "success");
                setTimeout(() => (window.location.href = "/"), 1000);
              } else {
                showToast(data.error || "Failed", "danger");
                btn.disabled = false;
                btn.innerText = "Disconnect Bot";
              }
            } catch (e) {
              showToast("Error connecting to server", "danger");
              btn.disabled = false;
              btn.innerText = "Disconnect Bot";
            }
          });
        }
      });

      async function toggleBot() {
        const btn = document.getElementById("toggle-bot-btn");
        const text = document.getElementById("toggle-bot-text");
        const icon = document.getElementById("toggle-bot-icon");
        const heroBtn = document.getElementById("hero-toggle-bot-btn");
        const heroText = document.getElementById("hero-toggle-bot-label");
        const heroIcon = document.getElementById("hero-toggle-bot-icon");
        const heroTitle = document.getElementById("dashboard-hero-title");
        const heroCopy = document.getElementById("dashboard-hero-copy");
        const overviewStatusIcon = document.getElementById("overview-status-icon");
        const feedStatus = document.getElementById("dashboard-feed-status");
        const quickBot = document.getElementById("dashboard-quick-bot");
        const quickBotValue = document.getElementById("dashboard-quick-bot-value");
        const statusText = document.getElementById("bot-status-text");
        const statusSubtitle = document.getElementById("bot-status-subtitle");
        const indicator = document.getElementById("bot-status-indicator");

        const originalText = text.innerText;
        text.innerText = "Wait...";
        btn.disabled = true;
        if (heroBtn) heroBtn.disabled = true;
        if (heroText) heroText.innerText = "Wait...";

        try {
          const res = await fetch("/api/toggle-bot", {
            method: "POST",
            headers: getCsrfHeaders(),
          });
          const data = await res.json();

          if (data.success) {
            const isEnabled = data.bot_enabled;

            // Update Button
            btn.className = `btn ${
                isEnabled ? "btn-danger-solid" : "btn-success-solid"
              }`;
            text.innerText = isEnabled ? "Turn Off" : "Turn On";
            icon.className = `fas ${isEnabled ? "fa-power-off" : "fa-play"}`;

            if (heroBtn) {
              heroBtn.className = `btn btn-sm ${
                isEnabled ? "btn-danger-solid" : "btn-success-solid"
              }`;
              heroBtn.disabled = false;
            }
            if (heroText) heroText.innerText = isEnabled ? "Turn off" : "Turn on";
            if (heroIcon) heroIcon.className = `fas ${isEnabled ? "fa-power-off" : "fa-play"}`;

            // Update Status Display
            statusText.innerText = isEnabled ? "Active" : "Inactive";
            statusSubtitle.innerText = isEnabled ?
              "Connected to chat" :
              "Bot is currently offline";

            indicator.className = isEnabled ?
              "indicator-success" :
              "indicator-danger";

            if (heroTitle) {
              heroTitle.innerText = isEnabled ?
                "Bot is live" :
                "Bot is offline";
            }
            if (heroCopy) {
              heroCopy.innerText = isEnabled ?
                "Rank commands are available in chat." :
                "Turn the bot on when you are ready for chat commands.";
            }
            if (overviewStatusIcon) {
              overviewStatusIcon.className = `overview-strip-icon ${isEnabled ? "" : "is-offline"}`;
              const iconNode = overviewStatusIcon.querySelector("i");
              if (iconNode) iconNode.className = `fas ${isEnabled ? "fa-signal" : "fa-pause"}`;
            }
            if (feedStatus) feedStatus.innerText = isEnabled ? "Connected" : "Offline";
            if (quickBot) {
              quickBot.className = `overview-pill ${isEnabled ? "is-good" : "is-warning"}`;
            }
            if (quickBotValue) quickBotValue.innerText = isEnabled ? "Live" : "Off";

            showToast(`Bot turned ${isEnabled ? "on" : "off"}`, "success");
            btn.disabled = false;

            // Refresh onboarding progress
            setTimeout(checkOnboardingProgress, 500);
          } else {
            showToast("Failed to toggle bot status.", "danger");
            text.innerText = originalText;
            btn.disabled = false;
            if (heroBtn) heroBtn.disabled = false;
            if (heroText) heroText.innerText = originalText === "Turn Off" ? "Turn off" : "Turn on";
          }
        } catch (err) {
          console.error("Error toggling bot:", err);
          showToast("An error occurred. Please try again.", "danger");
          text.innerText = originalText;
          btn.disabled = false;
          if (heroBtn) heroBtn.disabled = false;
          if (heroText) heroText.innerText = originalText === "Turn Off" ? "Turn off" : "Turn on";
        }
      }
    </script>
    <script src="/js/feedback.js"></script>
  </body>
</html>
